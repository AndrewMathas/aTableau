#! /usr/bin/env bash

# Create tar file for uploading atableau package to ctan
# In particular, this deletes the \__atableau_debug:n commands from
# atableau.sty

CTANIFY="ctanify -p atableau -nos"

TAR=$(tar --version)
GTAR=$(gtar --version)

if [[ "$TAR" != "$GTAR" ]]
then
  # use gnu-tar because tar on macosx adds spurious system files
  echo "WARNING: tar is not gnu-tar!"
fi

# create a copy of atableau.sty so that we can remove the debug commands
/bin/mv atableau.sty atableau-dev.sty
gsed '/__atableau_debug:n/d' atableau-dev.sty > atableau.sty

# create the tar file for ctan
$CTANIFY atableau.{ini,sty,pdf,tex} atableau_beamer.{pdf,tex} atableau_readme.webp DEPENDS.txt {CHANGES,README,TODO}.md LICENSE

# restore the debug commands
/bin/mv atableau-dev.sty atableau.sty

# remind user to check version number and the copyright and release dates
echo "Check version, release date and the copyright years in atableau.sty"
ag --nonumbers "@(release|version)" atableau.sty  | ag def
ag --nonumbers "copyright" atableau.sty
ag --nonumbers "(version|date|copyright)\s=" atableau.ini
ag --nonumbers "copy" README.md
