  % all tikz settings are in the atableau family
  atableau/.is~family,
    atableau/.cd,
    node/.style = {
        draw           = \l__atableau_inner_tl,
        fill           = \l__atableau_fill_tl,
        inner~sep      = 0pt,
        minimum~height = \fp_to_decimal:N \l__atableau_height_fp cm,
        minimum~width  = \fp_to_decimal:N \l__atableau_width_fp cm,
        shape          = \l__atableau_shape_tl,
        execute~at~begin~node = {
          % copy the font and text colour, as they might be changed by the style settings
