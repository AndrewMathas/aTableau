% \__atableau_residue:nn computes the residue of #1 mod #2. This is
% positive integer remainder when dividing by #2. As with \int_mod:n,
% the result is left in the % input stream.
\cs_new_nopar:Npn \__atableau_residue:nn #1 #2
{
    \int_compare:nTF {#1 > 0}
        { \int_mod:nn {#1} {#2} }
        { \int_eval:n {\int_mod:nn {#2 + \int_mod:nn {#1} {#2}} {#2}} }% \int_mod:nn is negative
}
% ---------------------------------------------------------------------------
% Parsing input

% Read the next entry in the input sequence, with any optional style, and give
% this data to the command \__atableau_#1:nn.
\cs_new_protected_nopar:Npn \__atableau_read_style:nw #1
{
\typeout{reading~style~with~1=#1.}
    \peek_charcode:NTF [
      { \use:c{__atableau_#1} }
      {
        \peek_charcode_remove:NTF * {\use:c{__atableau_#1} [atableau/starstyle]}
                                    {\use:c{__atableau_#1} []}
      }
}

% To parse the bead specifications used by \Abacus we need to accept the
% a "bead specification" of the following form
%    [style]m^k_txt
% where the [style] could simply be a *, the m is a part of the partition
% being constructed, the k its exponent and txt is the text for the node.
% Except for m, all of of these components are optional, with the exponent
% being 1 if it is omitted. As is customary, the order of the superscript and
% subscript is interchangeable. To parse these expressions we first use
% \__atableau_read_style:nw to strip off the style specification, via
% \__atableau_record_style:nn, and then pass between \__atableau_capture_bead:nw and
% \__atableau_record:nn to look ahead for the characters ^ and _ to
% decide which of the following token lists the next character is added to:
\tl_new:N \l__atableau_bead_exp_tl    % will contain the exponent
\tl_new:N \l__atableau_bead_part_tl   % will contain the part
\tl_new:N \l__atableau_bead_style_tl  % will contain the style
\tl_new:N \l__atableau_bead_text_tl   % will contain the text
\cs_new_protected_nopar:Npn \__atableau_record_style:nn [#1] #2
{
    \tl_set:Nn \l__atableau_bead_style_tl {#1}
    \tl_set:Nn \l__atableau_bead_part_tl {#2}
    \tl_clear:N \l__atableau_bead_exp_tl
    \tl_clear:N \l__atableau_bead_text_tl
    \__atableau_capture_bead:nw {part}
}

\cs_new_protected_nopar:Npn \__atableau_capture_bead:nw #1
{
    \peek_charcode_remove:NTF _
      { \__atableau_record_bead:nn {text} {}}
      {
        \peek_charcode_remove:NTF ^ { \__atableau_record_bead:nn {exp} {}}
                                    { \__atableau_record_bead:nn {#1} }
      }
}
\cs_new_protected_nopar:Npn \__atableau_record_bead:nn #1 #2
{
    \quark_if_recursion_tail_stop_do:nn {#2}
    {
        % the data in the sequences \l__atableau_bead_exp_tl times
        \tl_if_empty:NT \l__atableau_bead_exp_tl { \tl_set:Nn \l__atableau_bead_exp_tl {1}}
        \typeout{Saving~part=\tl_use:N\l__atableau_bead_part_tl,~style=\l__atableau_bead_style_tl,~text=\l__atableau_bead_text_tl,~exp=\l__atableau_bead_exp_tl.}
        \int_step_inline:nn { \l__atableau_bead_exp_tl }
        {
            \int_incr:N \l__atableau_beads_int
            \seq_put_right:No \l__atableau_shape_seq {\l__atableau_bead_part_tl}
            \seq_put_right:No \l__atableau_text_seq  {\l__atableau_bead_text_tl}
            \seq_put_right:No \l__atableau_style_seq {\l__atableau_bead_style_tl}
        }
    }
\typeout{Recording~#2~in~#1.}
    \tl_put_right:cn {l__atableau_bead_#1_tl} {#2}
    \__atableau_capture_bead:nw {#1}
}


% \__atableau_set_partition:nn {shape|skew} {csv for partition}
% This function allows the partition to be given either as a comma separated
% list of integers, or as a comma separated list of integers with exponents
% giving the multiplicity of each part. For example, 4,3,3,3,2 and 4,3^3,2are
% both supported.
% TODO? Rewrite using quarks?
\cs_new_protected_nopar:Npn \__atableau_set_partition:nn #1 #2
{
  %\group_begin:
    % change the category code of ^ to a letter
  %  \char_set_catcode_letter:N \^
    \seq_clear:N \g_tmpb_seq
    \clist_map_inline:nn {#2} { \__atableau_add_to_partition:n {##1} }
  %\group_end:
  \seq_set_eq:cN {l__atableau_#1_seq} \g_tmpb_seq
  \typeout{ginished~set~partition}
}

% \__atableau_compute_conjugate_partition:N {seq}
% compute the conjugate partition and store in \l__atableau_conjugate_seq
\cs_new_protected_nopar:Npn \__atableau_compute_conjugate_partition:N #1
{
    \seq_clear:N \l__atableau_conjugate_seq
    \int_zero:N \l_tmpa_int % previous part
    \int_set:No \l__atableau_r_int {\seq_count:N #1}
\typeout{Starting~with~tmpa=\int_use:N\l_tmpa_int,~row=\int_use:N\l__atableau_r_int}
    \int_while_do:nn {\l__atableau_r_int > 0}
    {
        \int_set:No \l_tmpb_int {\seq_item:NV #1 \l__atableau_r_int }
        \int_step_inline:nn { \l_tmpb_int - \l_tmpa_int }
        {
            \seq_put_right:NV \l__atableau_conjugate_seq \l__atableau_r_int
        }
        \int_set_eq:NN \l_tmpa_int \l_tmpb_int
        \int_decr:N \l__atableau_r_int
    }
}

% add parts to the partition \g__tmpc_seq given input
% of the form k or k^r
\cs_new_protected_nopar:Npn \__atableau_add_to_partition:n #1
{
    % split #1 on ^: the trailing ^1 sets the exponent to 1 if it's omitted
    \seq_set_split:Nnn \l_tmpa_seq {^} {#1 ^1}
    % given k or k^r, set \l_tmpa_int=k and \l_tmpb_int=r, where r=1 with input k
    \seq_pop_left:NN  \l_tmpa_seq \l_tmpa_tl % part
    \seq_pop_left:NN \l_tmpa_seq \l_tmpb_tl  % exponent
    % now add \l_tmpa_int to \g_tmpb_seq b times
    \int_step_inline:nn {\l_tmpb_tl} { \seq_gput_right:Ne \g_tmpb_seq {\l_tmpa_tl} }
    \typeout{a=\tl_use:N\l_tmpa_tl,~b=\tl_use:N \l_tmpb_tl,~PARTITION:~(\seq_use:Nn \g_tmpb_seq {,})}
}

% Young diagrams are drawn using the \Tableau command together with the
% \__atableau_diagram_for_shape:N converts a partition/seq into a
% clist of dots. For example, it replaces the sequence 3,2,2,1 with
% the dot-sequence ...,..,..,.,
\cs_new_protected_nopar:Npn \__atableau_diagram_for_shape:N #1
{
    \tl_clear:N \l__atableau_entries_tl
    \seq_map_inline:Nn #1
    {
        \tl_put_right:Nx \l__atableau_entries_tl  {\prg_replicate:nn {##1} {{{~}}} ,}
    }
}

% Contents diagrams are drawn using the \Tableau command, with
% \__atableau_shape_to_content:Nn {partition sequence} {charge} supplying the content sequence
\cs_new_protected_nopar:Npn \__atableau_shape_to_content:Nn #1 #2
{
    \tl_clear:N \l__atableau_entries_tl
    \int_zero:N \l__atableau_row_int
    \seq_map_inline:Nn #1
    {
        \int_incr:N \l__atableau_row_int
        \int_step_inline:nn {##1}
        {
            \tl_set:Ne \l_tmpc_tl { \int_eval:n{\seq_item:Nn \l__atableau_charge_seq {#2} ####1 - \l__atableau_row_int} }
            \__atableau_tl_put_right_braced:NV \l__atableau_entries_tl \l_tmpc_tl
        }
        \tl_put_right:Nn \l__atableau_entries_tl {,}
    }
    \typeout{********************* content *********************}
    \typeout{\tl_use:N \l__atableau_entries_tl}
    \typeout{************************************************}
}

% Contents diagrams are drawn using the \Tableau command, with
% \__atableau_shape_to_final:Nn {partition sequence} {charge}
\cs_new_protected_nopar:Npn \__atableau_shape_to_final:Nn #1 #2
{
    % compute conjugate of #1 as \l__atableau_conjugate_seq
    \__atableau_compute_conjugate_partition:N #1
    \seq_clear:N \l_tmpc_seq % construct the tableau in this sequence and then decant
    \int_set:Nn \l__atableau_c_int {\seq_item:Nn \l__atableau_charge_seq {#2} }
    % initialise \l_tmpc_seq -- should not be necessary but otherwise \seq_item:NV fails
    \seq_map_inline:Nn  \l__atableau_conjugate_seq {\seq_put_right:Nn \l_tmpc_seq {}}
    \seq_map_inline:Nn  \l__atableau_conjugate_seq
    {
        \int_zero:N \l__atableau_r_int
        \typeout{final:~adding~##1.}
        \int_step_inline:nn {##1}
        {
            \int_incr:N \l__atableau_r_int  % row index
            \int_incr:N \l__atableau_c_int  % tableau entry
        \typeout{final:~##1->r=\int_use:N\l__atableau_r_int,~c=\int_use:N\l__atableau_c_int}
            \tl_set:Nx \l_tmpa_tl {\seq_item:NV \l_tmpc_seq \l__atableau_r_int }
            \__atableau_tl_put_right_braced:NV \l_tmpa_tl \l__atableau_c_int
            \seq_set_item:Nno \l_tmpc_seq \l__atableau_r_int \l_tmpa_tl
        }
    }
    % finally, unpack \l_tmpc_tl into l__atableau_entries_tl
    \tl_clear:N \l__atableau_entries_tl
    \seq_map_inline:Nn \l_tmpc_seq {\tl_put_right:Nn \l__atableau_entries_tl {##1,}}
    \typeout{********************* final *********************}
    \typeout{\tl_use:N \l__atableau_entries_tl}
    \typeout{************************************************}
}

% Contents diagrams are drawn using the \Tableau command, with
% \__atableau_shape_to_initial:Nn {partition sequence} {charge}
\cs_new_protected_nopar:Npn \__atableau_shape_to_initial:Nn #1 #2
{
    \tl_clear:N \l__atableau_entries_tl
    \int_set:Nn \l__atableau_r_int {\seq_item:Nn \l__atableau_charge_seq {#2} }
    \seq_map_inline:Nn #1
    {
        \int_step_inline:nn {##1}
        {
            \int_incr:N \l__atableau_r_int
            \__atableau_tl_put_right_braced:NV \l__atableau_entries_tl \l__atableau_r_int
        }
        \tl_put_right:Nn \l__atableau_entries_tl {,}
    }
    \typeout{********************* initial *********************}
    \typeout{\tl_use:N \l__atableau_entries_tl}
    \typeout{************************************************}
}

% Hook length diagrams are drawn using the \Tableau command, with
% \__atableau_shape_to_hook:N supplying the sequence of hook lengths
\cs_new_protected_nopar:Npn \__atableau_shape_to_hook:N #1
{
    % compute conjugate of #1 as \l__atableau_conjugate_seq
    \__atableau_compute_conjugate_partition:N #1
    % now construct the hook tableau
    \tl_clear:N \l__atableau_entries_tl
    \int_zero:N \l__atableau_row_int
    \seq_map_inline:Nn #1
    {
        \int_incr:N \l__atableau_row_int
        \int_step_inline:nn {##1}
        {
    \typeout{conjugate:~(\seq_use:Nn \l__atableau_conjugate_seq {,})}
            \tl_set:Ne \l_tmpc_tl { \int_eval:n {##1+\seq_item:Nn \l__atableau_conjugate_seq {####1} -\l__atableau_row_int-####1+1} }
            \__atableau_tl_put_right_braced:NV \l__atableau_entries_tl \l_tmpc_tl
        }
        \tl_put_right:Nn \l__atableau_entries_tl {,}
    }
    \typeout{********************* hook *********************}
    \typeout{\tl_use:N \l__atableau_entries_tl}
    \typeout{************************************************}
}

% Residue diagrams are drawn using the \Tableau command, with
% \__atableau_shape_to_content:Nn {partition sequence} {charge}
\cs_new_protected_nopar:Npn \__atableau_shape_to_residue:Nn #1 #2
{
    \tl_clear:N \l__atableau_entries_tl
    \int_zero:N \l__atableau_row_int
    \typeout{res:~(\seq_use:Nn #1 {,})}
    \seq_map_inline:Nn #1
    {
        \int_incr:N \l__atableau_row_int
    \typeout{m=##1,~r=\int_use:N\l__atableau_row_int}
        \int_step_inline:nn {##1}
        {
        \typeout{residue:~m=##1,~r=\int_use:N\l__atableau_row_int,~c=####1,~charge=\seq_item:Nn \l__atableau_charge_seq {#2}.}
            \int_set:Nn \l_tmpa_int {####1 - \l__atableau_row_int + \seq_item:Nn \l__atableau_charge_seq {#2}}
            \tl_set:Nx \l_tmpc_tl { \__atableau_residue:nn { \l_tmpa_int } {\l__atableau_e_int} }
        \typeout{con=\int_use:N\l_tmpa_int,~res=\tl_use:N\l_tmpc_tl,~e=\int_use:N\l__atableau_e_int}
            \__atableau_tl_put_right_braced:Nx \l__atableau_entries_tl \l_tmpc_tl
        }
        \tl_put_right:Nn \l__atableau_entries_tl {,}
    }
    \typeout{********************* residue *********************}
    \typeout{\tl_use:N \l__atableau_entries_tl}
    \typeout{************************************************}
}

% ---------------------------------------------------------------------------
% draw diagram outline

% \__atableau_draw_outline:nn #1 #2 {name of sequence} {name of style}
\cs_new_protected_nopar:Npn \__atableau_draw_outline:nn #1 #2
{
\typeout{starting~outline~for~shape=#1,~style=#2.}
\typeout{shape=(\seq_use:cn {l__atableau_#1_seq} {,})}
    \int_zero:N \l__atableau_r_int  % row index
    \int_zero:N \l__atableau_c_int  % column index
    \tl_clear:N \l__atableau_outline_tl % will hold the outline
    \seq_map_inline:cn {l__atableau_#1_seq}
    {
    \typeout{~-~starting~##1...}
        \int_set:Nn \l_tmpa_int {0##1}
        \typeout{~-~adding~##1~->~\int_use:N\l_tmpa_int}
        \int_compare:nNnT \l_tmpa_int > {0} % only add outlines for nonzero rows
        {
            % compute the endpoints of this row
            \str_if_eq:nnF {skew} {#1}
            {
                \int_set:Nn \l__atableau_c_int { 0\seq_item:Nn \l__atableau_skew_seq {\l__atableau_r_int+1}}
            }
            \__atableau_set_coordinates:nVV {a}  \l__atableau_r_int \l__atableau_c_int
            \__atableau_set_coordinates:nVn {b} \l__atableau_r_int {##1}
            \int_compare:nNnTF {\l__atableau_r_int} = {0}
            {   % add line at "top" of the diagram
                \tl_set:Nx \l__atableau_outline_tl {(\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_ya_fp)--(\fp_use:N\l__atableau_xb_fp,\fp_use:N\l__atableau_yb_fp)}

                \bool_if:NF \l__atableau_tabloid_bool { \__atableau_add_row_ends: }
            }
            { % add lines for second and later rows

              % add ends under the row
                \tl_put_left:Nx  \l__atableau_outline_tl {(\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_ya_fp)--}
                \tl_put_right:Nx \l__atableau_outline_tl {--(\fp_use:N\l__atableau_xb_fp,\fp_use:N\l__atableau_yb_fp)}
                \bool_if:NTF \l__atableau_tabloid_bool
                {
                    % fill in the line
                    \tl_put_right:Nx \l__atableau_outline_tl {(\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_ya_fp)--(\fp_use:N\l__atableau_xb_fp,\fp_use:N\l__atableau_yb_fp)}
                }
                {
                    \bool_if:NF \l__atableau_tabloid_bool \__atableau_add_row_ends:
                }
            }
            \int_incr:N \l__atableau_r_int
            \typeout{Outline~\int_use:N\l__atableau_r_int~:~\tl_use:N\l__atableau_outline_tl.}
        }
    }
    \typeout{finished~main~diagram}

    \tl_if_empty:NF \l__atableau_outline_tl
    {
      % fill in the last line
      \tl_put_right:Nx \l__atableau_outline_tl {(\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_ya_fp)--(\fp_use:N\l__atableau_xb_fp,\fp_use:N\l__atableau_yb_fp)}

      \typeout{outline=\tl_use:N\l__atableau_outline_tl.}
      % finally,draw the outline
      \draw[atableau/#2] \l__atableau_outline_tl;
    }
}

% \__atableau_add_row_ends: increment the (xa,ya) and (xb,yb) coordinates down
% one row and add the lines at the left and right hand ends of the row to
% \l__atableau_outline_tl
\cs_new_protected_nopar:Nn \__atableau_add_row_ends:
{
    % add the left-hand side
    \fp_add:Nn \l__atableau_xa_fp {\l__atableau_row_dx_fp*\l__atableau_width_fp}
    \fp_add:Nn \l__atableau_ya_fp {\l__atableau_row_dy_fp*\l__atableau_height_fp}
    \tl_put_left:Nx \l__atableau_outline_tl {(\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_ya_fp)--}

    % add the right-hand side
    \fp_add:Nn \l__atableau_xb_fp {\l__atableau_row_dx_fp*\l__atableau_width_fp}
    \fp_add:Nn \l__atableau_yb_fp {\l__atableau_row_dy_fp*\l__atableau_height_fp}
    \tl_put_right:Nx \l__atableau_outline_tl {--(\fp_use:N\l__atableau_xb_fp,\fp_use:N\l__atableau_yb_fp)}
}

% ---------------------------------------------------------------------------
% Tableaux

% usage: \__atableau_tableau:nnnn {entries} {style} (x,y)
% The entries are first primarily because the \Diagram commands need
% to force the entries to expand
\cs_new_protected_nopar:Npn \__atableau_tableau:nnnn #1 #2 (#3,#4)
{
\typeout{----------------------------------------------------------------------------}
\typeout{tableau:~1=|#1|,~2=#2,~(x,y)=(#3,#4)}
    % using a group makes any changes to the atableau settings local
    \group_begin:
        \__atableau_set_style:nV {tableau} \l__atableau_tableau_style_tl
        \keys_set:nn {atableau} {#2}
        \fp_set:Nn \l__atableau_x_fp {#3}
        \fp_set:Nn \l__atableau_y_fp {#4}
        \seq_clear:N \l__atableau_shape_seq
        \int_zero:N \l__atableau_row_int
        \bool_if:NT \l__atableau_shifted_bool { \seq_clear:N \l__atableau_skew_seq }
        \typeout{About~to~map!}
        \seq_set_split:Nnn \l__atableau_row_seq {,} {#1}
        \seq_map_inline:Nn \l__atableau_row_seq
        {
            % if shifted is true then add row to the skew shape
            \bool_if:NT \l__atableau_shifted_bool { \seq_put_right:NV \l__atableau_skew_seq \l__atableau_row_int }

            % the leading 0 catches the case when the skew shape has fewer rows than \l__atableau_row_int
            \int_set:Nn \l__atableau_col_int { 0\seq_item:Nn \l__atableau_skew_seq {\l__atableau_row_int+1}}

            \typeout{****~reading:~|##1|}
            % process the entries in this row
            \__atableau_read_style:nw {draw_entry:nn} ##1 \q_recursion_tail \q_recursion_stop

            % increment the row index, record this in the shape, and repeat
            \int_incr:N \l__atableau_row_int

            % record the shape for drawing out the outline
            \seq_put_right:NV \l__atableau_shape_seq \l__atableau_col_int
        }
        % add any ribbons
        \seq_map_inline:Nn \l__atableau_ribbons_seq {\__atableau_add_ribbon:n {##1}}

        % draw outline
        \typeout{drawing~outline}
        \bool_if:NT \l__atableau_skewwall_bool { \__atableau_draw_outline:nn {skew}  {skewwall}  }
        \bool_if:NT \l__atableau_outline_bool  { \__atableau_draw_outline:nn {shape} {outerwall} }

    \group_end:
}

% \__atableau_set_coordinates:nnn [nl] <row> <col>: given the row and columns
% indices, row and col, define the corresponding coordinates:
%  - \l__atableau_xl_fp : x-coordinats
%  - \l__atableau_yl_fp : y-coordinate
%  - \l__atableau_name_tl : the node name
% Used by both the tableaux and abacus commands
\cs_new_protected_nopar:Npn \__atableau_set_coordinates:nnn #1 #2 #3
{
\typeout{~-~setting~coordinates:~#1=(#2,#3).}
    \tl_set:Nx \l__atableau_name_tl {\l__atableau_prefix_tl-\int_eval:n{1+#2}-\int_eval:n {1+#3}}
    \fp_set:cn {l__atableau_x#1_fp} {\l__atableau_x_fp+(#2*\l__atableau_row_dx_fp+#3*\l__atableau_col_dx_fp)*\l__atableau_width_fp}
    \fp_set:cn {l__atableau_y#1_fp} {\l__atableau_y_fp+(#2*\l__atableau_row_dy_fp+#3*\l__atableau_col_dy_fp)*\l__atableau_height_fp}

    % update the maximum row and column indices for use by multitableau/multidiagrams
    \int_compare:nNnT { \g__atableau_row_max_int } < { \l__atableau_row_int }
                      { \int_gset_eq:NN \g__atableau_row_max_int \l__atableau_row_int }
    \int_compare:nNnT { \g__atableau_col_max_int } < { \l__atableau_col_int }
                      { \int_gset_eq:NN \g__atableau_col_max_int \l__atableau_col_int }
    \typeout{~-~xl=\fp_use:N\l__atableau_xl_fp,~yl=\fp_use:N\l__atableau_yl_fp}

}

% ---------------------------------------------------------------------------
% node entry

% TODO:
%  - allow use of \hbox_overlap_left:n, \hbox_overlap_center:n, or \hbox_overlap_right:n ???
%  - hook to allow vertical alignment
%  - use TikZ styles for the nodes...perhaps using
%        \hbox_overlap_center:n {\tikz\node[atableau/box] at (0,0){$#1$}} etc ?

% We use \hbox_overlap_center:n to ensure that an entry does not change
% the size of the node when it is too large.
\cs_new_protected_nopar:Npn \__atableau_entry_math:n #1
{
%\hbox_overlap_center:n {\tikz{\node[atableau/box]at(0,0){$#1$};}}
\hbox_overlap_center:n {\color{\l__atableau_text_tl}\l__atableau_font_tl $#1$}
}
\cs_new_protected_nopar:Npn \__atableau_entry_text:n #1
{
\hbox_overlap_center:n  {\color{\l__atableau_text_tl}\l__atableau_font_tl #1}
%\hbox_overlap_center:n  {\tikz{\node[atableau/box]at(0,0){$#1$};}}%\color{\l__atableau_text_tl}\l__atableau_font_tl #1}
}

% By default tableau nodes are typeset in math-mode.
\cs_set_eq:NN \__atableau_entry:n \__atableau_entry_math:n

% \__atableau_draw_entry:nn [style] {entry}
% draw a node entry #2 in the tableau using the style #1
\cs_new_protected_nopar:Npn \__atableau_draw_entry:nn [#1] #2
{
    % exit when we reach the end of the row
    \quark_if_recursion_tail_stop:n {#2}

    \typeout{drawing~with~1=|#1|,~2=|#2|}
    % compute the node name and its (x,y)-coordinates
    \__atableau_set_coordinates:nVV {l} \l__atableau_row_int \l__atableau_col_int
    \typeout{drawing~with~style=#1,~entry="#2",row=\int_use:N\l__atableau_row_int,col=\int_use:N\l__atableau_col_int.}

    %\group_begin:
    %\keys_set:nn { atableau/node }{ #1 }
      \node[atableau/node,#1](\l__atableau_name_tl)
          at (\fp_use:N\l__atableau_xl_fp, \fp_use:N\l__atableau_yl_fp)
          {\__atableau_entry:n{#2}};
    %\group_end:

    % recurse
    \int_incr:N \l__atableau_col_int
    \__atableau_read_style:nw {draw_entry:nn}
}

% ---------------------------------------------------------------------------
% multitableau and their diagrams

% Inserts a separator between the different components of multitableau and
% multidiagrams. Requires that \l__atableau_component_int is greater than 1
% and that the requisite flags are set. The location of the separator is
% controlled by
%   - \l__atableau_separation_fp
%   - \g__atableau_col_max_int
%   -\g__atableau_row_max_int
\cs_new_protected_nopar:Npn \__atableau_insert_separator:n #1
{
    \int_compare:nNnT {\l__atableau_component_int} > {0}
    {
    \typeout{*****************}
    \typeout{Separating!~Comp=\int_use:N\l__atableau_component_int,~row~max=\int_use:N\g__atableau_row_max_int,~col~max=\int_use:N\g__atableau_col_max_int,row=\int_use:N\l__atableau_row_int,col=\int_use:N\l__atableau_col_int,~dx=\fp_use:N\l__atableau_col_dx_fp,~dy=\fp_use:N\l__atableau_row_dy_fp,~height=\fp_use:N\l__atableau_height_fp}
        % the rows setting overrides row_max
        \int_compare:nNnT {\l__atableau_rows_int} > {0}
            { \int_gset_eq:NN \g__atableau_row_max_int \l__atableau_rows_int }
        \int_compare:nNnT {\l__atableau_cols_int} > {0}
            { \int_gset_eq:NN \g__atableau_col_max_int \l__atableau_cols_int }
        \__atableau_set_coordinates:nVV {l} \g__atableau_row_max_int \g__atableau_col_max_int
        \fp_add:Nn \l__atableau_yl_fp {\l__atableau_row_dy_fp*\l__atableau_height_fp/2}

        \__atableau_set_coordinates:nnV {a} {0} \g__atableau_col_max_int
        \fp_add:Nn \l__atableau_xa_fp {\l__atableau_col_dx_fp*\l__atableau_width_fp/2+\l__atableau_separation_fp/2}
        \fp_sub:Nn \l__atableau_ya_fp {\l__atableau_row_dy_fp*\l__atableau_height_fp/2}

        % add the separator
        \str_case:enF {#1} {
        {|} {
                \draw[atableau/separator](\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_ya_fp)--(\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_yl_fp);
            }
        }
        {   % any other separator is assumed to be text
        \typeout{adding~node~text:~"#1"}
            \node[atableau/separator] at (\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_ya_fp){#1};
            \hbox_set:Nn \l_tmpa_box {#1}
            \fp_add:Nn \l__atableau_x_fp {\box_wd:N \l_tmpa_box}
        }

        % finally, increment x by the separation amount
        \fp_set:Nn \l__atableau_x_fp {\l__atableau_xa_fp+\l__atableau_col_dx_fp*\l__atableau_width_fp/2+\l__atableau_separation_fp/2}
    }
    % reset the (row and) column max
    \int_gset:Nn \g__atableau_row_max_int {0}
    \int_gset:Nn \g__atableau_col_max_int {0}
}


% usage: \__atableau_multidiagram:nnnn {entries} {style} (x,y)
% The entries are first primarily because the \Diagram commands need
% to force the entries to expand
\cs_new_protected_nopar:Npn \__atableau_multidiagram:nnnn #1 #2 (#3,#4)
{
\typeout{----------------------------------------------------------------------------}
\typeout{multidiagram:~1="#1",~2=#2,~(x,y)=(#3,#4)}
    % using a group makes any changes to the atableau settings local
    \group_begin:
        \__atableau_set_style:nV {tableau} \l__atableau_tableau_style_tl
        \keys_set:nn {atableau} {#2}
        \fp_set:Nn \l__atableau_x_fp {#3}
        \fp_set:Nn \l__atableau_y_fp {#4}

        % track the component
        \int_zero:N \l__atableau_component_int

        % save the prefix name so that we can modify it
        \tl_set_eq:NN \l__atableau_multiprefix_tl \l__atableau_prefix_tl

        % separate the component partitions
        \seq_set_split:Nnn \l__atableau_component_seq {||} {#1}
        \seq_map_inline:Nn \l__atableau_component_seq
        {
        \typeout{Component:~\int_use:N\l__atableau_component_int}
            \__atableau_insert_separator:n \l__atableau_separator_tl
            \int_incr:N \l__atableau_component_int
            \tl_if_eq:nnTF {##1} {...}
               {
                   % insert dots
                   \__atableau_insert_separator:n {...}
               }
               {
                   % convert ##1 to the partition \l__atableau_shape_seq
                   \__atableau_set_partition:nn {shape} {##1}
                   % generate the dot-sequence for the partition
                   \__atableau_diagram_for_shape:N \l__atableau_shape_seq
                   \tl_set:No \l__atableau_prefix_tl {prefix=\tl_use:N\l__atableau_multiprefix_tl-\int_use:N\l__atableau_component_int}
                   \exp_args:NV \__atableau_tableau:nnnn \l__atableau_entries_tl {} (\fp_use:N\l__atableau_x_fp,\fp_use:N\l__atableau_y_fp)
               }
        }
    \group_end:
}

% usage: \__atableau_multitableau:nnnn {entries} {style} (x,y)
% The entries are first primarily because the \Diagram commands need
% to force the entries to expand
\cs_new_protected_nopar:Npn \__atableau_multitableau:nnnn #1 #2 (#3,#4)
{
\typeout{----------------------------------------------------------------------------}
\typeout{multitableau:~1="#1",~2=#2,~(x,y)=(#3,#4)}
    % using a group makes any changes to the atableau settings local
    \group_begin:
        \__atableau_set_style:nV {tableau} \l__atableau_tableau_style_tl
        \keys_set:nn {atableau} {#2}
        \fp_set:Nn \l__atableau_x_fp {#3}
        \fp_set:Nn \l__atableau_y_fp {#4}

        % track the component
        \int_zero:N \l__atableau_component_int

        % save the prefix name so that we can modify it
        \tl_set_eq:NN \l__atableau_multiprefix_tl \l__atableau_prefix_tl

        % separate the entries of the component tableaux
        \seq_set_split:Nnn \l__atableau_component_seq {|} {#1}
        \seq_map_inline:Nn \l__atableau_component_seq
        {
        \typeout{Component~\int_use:N\l__atableau_component_int="##1"}
            \__atableau_insert_separator:n \l__atableau_separator_tl
            \int_incr:N \l__atableau_component_int
            \tl_if_eq:nnTF {##1} {...}
               {
                   % insert dots
                   \__atableau_insert_separator:n {...}
               }
               {
                   % insert tableau
                   \tl_set:No \l__atableau_prefix_tl {prefix=\tl_use:N\l__atableau_multiprefix_tl-\int_use:N\l__atableau_component_int}
                   \__atableau_tableau:nnnn {{##1}} {} (\fp_use:N\l__atableau_x_fp,\fp_use:N\l__atableau_y_fp)
               }
        }
    \group_end:
}

% ---------------------------------------------------------------------------
% Ribbon tableaux

% \__atableau_ribbon_tableau:nnnn {ribbons} {style} (x,y)
% Draw a ribbon tableau. The ribbons are specified by
\cs_new_protected_nopar:Npn \__atableau_ribbon_tableau:nnnn #1 #2 (#3,#4)
{
\typeout{----------------------------------------------------------------------------}
\typeout{tableau:~1="#1",~2=#2,~(x,y)=(#3,#4)}
    % using a group makes any changes to the atableau settings local
    \group_begin:
        \__atableau_set_style:nV {tableau} \l__atableau_tableau_style_tl
        \keys_set:nn {atableau} {#2}
        \fp_set:Nn \l__atableau_x_fp {#3}
        \fp_set:Nn \l__atableau_y_fp {#4}
        \seq_clear:N \l__atableau_shape_seq
        \typeout{Ribboning:~}
        \clist_map_inline:nn {#1} { \__atableau_add_ribbon:n {##1} }
        % TODO: add the outline
    \group_end:
}

% \__atableau_add_ribbon:n {ribbon} add a ribbon to the tableau
\cs_new_protected_nopar:Npn \__atableau_add_ribbon:n #1
{
    \typeout{about~to~regex~"##1"}
    % process the entries in this row
    \regex_match:nnTF {\A[A-Za-z].*\|\s*\{?\s*\d*\s*\}*\s*\{?\s*\d*\s*\}?[\src]*\Z} {#1}
    {
    \typeout{matched!}
        \seq_set_split:Nnn \l_tmpa_seq {|} {#1}
        \seq_pop_left:NN \l_tmpa_seq \l__atableau_ribbon_style_tl
        \seq_pop_left:NN \l_tmpa_seq \l_tmpa_tl
    }
    {
    \typeout{did~not~match:(}
        \tl_set:Nn \l_tmpa_tl {#1}
        \tl_clear:N \l__atableau_ribbon_style_tl
    }
    \typeout{ribbon~|#1|~->~style="\tl_use:N\l__atableau_ribbon_style_tl",~ribbon="\l_tmpa_tl"}
    \exp_last_unbraced:Nnf \__atableau_read_style:nw {read_ribbon_head:nnn} \l_tmpa_tl \q_recursion_tail \q_recursion_stop
}

% Add the first node to the ribbon, with style, and set the row and column
% indices, and (xa,ya) and (xb,yb) % equal to the top left and bottom right
% coordinates of the node
\cs_new_protected_nopar:Npn \__atableau_read_ribbon_head:nnn [#1] #2 #3
{
\typeout{Starting~ribbon~at~(#2,#3)~with~style~"#1".}
    \int_set:Nn \l__atableau_row_int {#2-1}
    \int_set:Nn \l__atableau_col_int {#3-1}

    % add the named node with any styling: #1=style|entry
    \seq_set_split:Nnn \l_tmpa_seq {|} {#1|}
    \seq_pop_left:NN \l_tmpa_seq \l_tmpa_tl  % style
    \seq_pop_left:NN \l_tmpa_seq \l_tmpb_tl  % entry
    \__atableau_set_coordinates:nVV {l} \l__atableau_row_int \l__atableau_col_int
    \exp_last_unbraced:Nx  \node{[atableau/ribbon,\tl_use:N\l_tmpa_tl]}(\tl_use:N\l__atableau_name_tl)
        at (\fp_use:N\l__atableau_xl_fp, \fp_use:N\l__atableau_yl_fp) {\__atableau_entry:n{\tl_use:N\l_tmpb_tl}};

    % add initial coordinates to \l__atableau_ribbon_tl

    % 1. Make (xl,yl) the top corner of the ribbon and add it
    \fp_set:Nn \l__atableau_xl_fp {\l__atableau_xl_fp+(\l__atableau_row_dx_fp+\l__atableau_col_dx_fp)*\l__atableau_width_fp/2}
    \fp_set:Nn \l__atableau_yl_fp {\l__atableau_yl_fp-(\l__atableau_row_dy_fp+\l__atableau_col_dy_fp)*\l__atableau_height_fp/2}
    \tl_set:Nx \l__atableau_ribbon_tl { (\fp_use:N\l__atableau_xl_fp,\fp_use:N\l__atableau_yl_fp) }

    % 2. Make (xa,ya) the top left of the ribbon and add it on the left (decreasing column)
    \fp_set:Nn \l__atableau_xa_fp {\l__atableau_xl_fp-\l__atableau_col_dx_fp*\l__atableau_width_fp}
    \fp_set:Nn \l__atableau_ya_fp {\l__atableau_yl_fp-\l__atableau_col_dy_fp*\l__atableau_height_fp}
    \tl_put_left:Nx \l__atableau_ribbon_tl { (\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_ya_fp)-- }

    % 3, Make (xb,yb) the bottom right corner and add it on the right (increasing row)
    \fp_set:Nn \l__atableau_xb_fp {\l__atableau_xl_fp+\l__atableau_row_dx_fp*\l__atableau_width_fp}
    \fp_set:Nn \l__atableau_yb_fp {\l__atableau_yl_fp+\l__atableau_row_dy_fp*\l__atableau_height_fp}
    \tl_put_right:Nx \l__atableau_ribbon_tl { --(\fp_use:N\l__atableau_xb_fp,\fp_use:N\l__atableau_yb_fp) }

    \typeout{initial~ribbon=\tl_use:N\l__atableau_ribbon_tl,}
    % look at the next ribbon specification
    \__atableau_read_style:nw {read_ribbon_rc:nn}
}


% Read each successive r and c in the ribbon specification, together with
% style, draw the corresponding nodes and add the new coordinates to the
% ribbon \l__atableau_ribbon_tl. Finally, draw the ribbon.
% TODO: ribbon style + build the partition
\cs_new_protected_nopar:Npn \__atableau_read_ribbon_rc:nn [#1] #2
{
    \quark_if_recursion_tail_stop_do:nn {#2}
    {
    \typeout{finalising~ribbon}
          % Add the \draw command and the last node to the ribbon
          \fp_set:Nn \l__atableau_xa_fp {\l__atableau_xa_fp+\l__atableau_row_dx_fp*\l__atableau_width_fp}
          \fp_set:Nn \l__atableau_ya_fp {\l__atableau_ya_fp+\l__atableau_row_dy_fp*\l__atableau_height_fp}
          \tl_put_left:Nx \l__atableau_ribbon_tl { (\fp_use:N\l__atableau_xa_fp, \fp_use:N\l__atableau_ya_fp)-- }
          % add a closing cycle
          \tl_put_right:Nn \l__atableau_ribbon_tl {--cycle}

            \typeout{final~ribbon=\tl_use:N\l__atableau_ribbon_tl.}
          % draw the ribbon
          \exp_last_unbraced:Nx\draw{[atableau/innerwall, atableau/node, atableau/ribbon, \tl_use:N\l__atableau_ribbon_style_tl]}
              \l__atableau_ribbon_tl;
    }

    \str_case:enF {#2}
    {
        {c} { % move back one column
              \int_decr:N \l__atableau_col_int

              % Move (xa,ya) back one column add it to the ribbon on the left
              \fp_set:Nn \l__atableau_xa_fp {\l__atableau_xa_fp-\l__atableau_col_dx_fp*\l__atableau_width_fp}
              \fp_set:Nn \l__atableau_ya_fp {\l__atableau_ya_fp-\l__atableau_col_dy_fp*\l__atableau_height_fp}
              \tl_put_left:Nx \l__atableau_ribbon_tl { (\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_ya_fp)-- }

              % Move (xb,xb) back one column add it to the ribbon on the right
              \fp_set:Nn \l__atableau_xb_fp {\l__atableau_xb_fp-\l__atableau_col_dx_fp*\l__atableau_width_fp}
              \fp_set:Nn \l__atableau_yb_fp {\l__atableau_yb_fp-\l__atableau_col_dy_fp*\l__atableau_height_fp}
              \tl_put_right:Nx \l__atableau_ribbon_tl { --(\fp_use:N\l__atableau_xb_fp,\fp_use:N\l__atableau_yb_fp) }
            }
        {r} { % move forward one row
              \int_incr:N \l__atableau_row_int

              % Move (xa,ya) forward one row add it to the ribbon on the left
              \fp_set:Nn \l__atableau_xa_fp {\l__atableau_xa_fp+\l__atableau_row_dx_fp*\l__atableau_width_fp}
              \fp_set:Nn \l__atableau_ya_fp {\l__atableau_ya_fp+\l__atableau_row_dy_fp*\l__atableau_height_fp}
              \tl_put_left:Nx \l__atableau_ribbon_tl { (\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_ya_fp)-- }

              % Move (xb,xb) forward one row add it to the ribbon on the right
              \fp_set:Nn \l__atableau_xb_fp {\l__atableau_xb_fp+\l__atableau_row_dx_fp*\l__atableau_width_fp}
              \fp_set:Nn \l__atableau_yb_fp {\l__atableau_yb_fp+\l__atableau_row_dy_fp*\l__atableau_height_fp}
              \tl_put_right:Nx \l__atableau_ribbon_tl { --(\fp_use:N\l__atableau_xb_fp,\fp_use:N\l__atableau_yb_fp) }
            }
    }
    {
        \msg_error:nnx {aTableau} {invalid-ribbon-specification} {#2}
    }

    \typeout{Adding~to~ribbon~with~1=#1,~2=#2:~row=\int_use:N\l__atableau_row_int,~col=\int_use:N\l__atableau_col_int}
    \typeout{ribbon=\tl_use:N\l__atableau_ribbon_tl.}

    % add the named node with any styling: #1=style|entry
    \seq_set_split:Nnn \l_tmpa_seq {|} {#1|}
    \seq_pop_left:NN \l_tmpa_seq \l_tmpa_tl  % style
    \seq_pop_left:NN \l_tmpa_seq \l_tmpb_tl  % entry
    \__atableau_set_coordinates:nVV {l} \l__atableau_row_int \l__atableau_col_int
    \typeout{Style="#1"}
    \typeout{Applying~ribbon~with~style~>\tl_use:N\l_tmpa_tl<~and~entry~>\tl_use:N\l_tmpb_tl<}
    \exp_last_unbraced:Nx \node{[atableau/ribbon,\tl_use:N\l_tmpa_tl]}(\tl_use:N\l__atableau_name_tl)
            at (\fp_use:N\l__atableau_xl_fp, \fp_use:N\l__atableau_yl_fp) {\__atableau_entry:n{\tl_use:N\l_tmpb_tl}};




    % look at the next ribbon specification
    \__atableau_read_style:nw {read_ribbon_rc:nn}
}

% ---------------------------------------------------------------------------

% abacuses

% \__atableau_abacus:nnnn {style} (x,y) {#runners} {partition+style}
\cs_new_protected_nopar:Npn \__atableau_abacus:nnnn #1 (#2,#3) #4 #5
{
\typeout{Abacus:~1=#1,~(x,y)=(#2,#4),~4=#4,~5=#5}
    % using a group makes any changes to the aTableau settings local
    \group_begin:
        \__atableau_set_style:nV {abacus} \l__atableau_abacus_style_tl
        \keys_set:nn {atableau} {#1}
        \fp_set:Nn \l__atableau_x_fp {#2}
        \fp_set:Nn \l__atableau_y_fp {#3}
        \int_set:Nn \l__atableau_cols_int {#4}

        % Extract the bead positions and their styles into
        % \l__atableau_shape_seq, \l__atableau_style_seq and \l__atableau_text
        % We allow all of the following expressions
        %   m, m^r, [style]m, [style]m^2, *m, *m^2,
        %   m_text, m_text^r, [style]m_text, [style]m_text^2, *m_text, *m_text^2,
        %   m_text^r, [style]m_text^2, *m_text^2
        % where m is a part of the partition \l__atableau_shape_seq and r is
        % its' exponent. First, clear all of the sequences and zero the bead
        % counter
        \seq_clear:N \l__atableau_shape_seq % will record the partition
        \seq_clear:N \l__atableau_style_seq % will record the bead style
        \seq_clear:N \l__atableau_text_seq  % will record the bead text
        \int_zero:N \l__atableau_beads_int  % will record the number of beads
        \clist_map_inline:nn {#5}
        {
            \__atableau_read_style:nw {record_style:nn} ##1  \q_recursion_tail \q_recursion_stop
        }

        % unless they have been set, determine the number of abacus rows
        \int_compare:nNnT {\l__atableau_rows_int} = {0}
        {
            \typeout{initial=\int_use:N \l_tmpa_int}
            \int_set:No \l__atableau_rows_int { \int_div_truncate:nn {\l__atableau_beads_int + \seq_item:Nn \l__atableau_shape_seq 1} {#4} }
        }
        \typeout{Abacus~with~\int_use:N\l__atableau_rows_int~\space~rows~and~\int_use:N\l__atableau_cols_int~\space~runners~from~max=\seq_item:Nn \l__atableau_shape_seq 1,~e=#4.}
        \int_zero:N \l__atableau_col_int
        \int_step_inline:nn {\l__atableau_cols_int}
        {
            \typeout{adding~runner~##1~<~\int_use:N\l__atableau_cols_int}
            % draw the abacus runners
            \__atableau_set_coordinates:nnn {l} {0} { \int_eval:n{##1-1} }
            \__atableau_set_coordinates:nVo {a} \l__atableau_rows_int { \int_eval:n{##1-1} }
        \typeout{Drawing~runner~\int_use:N\l__atableau_row_int :~(\fp_use:N\l__atableau_xl_fp,\fp_use:N\l__atableau_yl_fp)--(\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_ya_fp)}
            \draw[atableau/runner] (\fp_use:N\l__atableau_xl_fp,\fp_use:N\l__atableau_yl_fp)--(\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_ya_fp);
            % draw the ticks
            \typeout{About~to~add~\int_use:N\l__atableau_rows_int~\space~ticks~of~width~\fp_use:N\l__atableau_tick_width_fp.}
            \int_zero:N \l__atableau_row_int
            \int_step_inline:nn {\l__atableau_rows_int}
            {
            \typeout{adding~tick~####1~<~\int_use:N\l__atableau_rows_int}
            \__atableau_set_coordinates:noo {l} { \int_eval:n{####1-1} } { \int_eval:n{##1-1} }
                % add and subtract (half) tick width
                \fp_set:Nn \l__atableau_xa_fp {\l__atableau_xl_fp+\l__atableau_tick_width_fp}
                \fp_set:Nn \l__atableau_xl_fp {\l__atableau_xl_fp-\l__atableau_tick_width_fp}
                \typeout{ready~to~draw!~(\fp_use:N\l__atableau_xl_fp,\fp_use:N\l__atableau_yl_fp)--(\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_yl_fp)}
                \draw[atableau/tick] (\fp_use:N\l__atableau_xl_fp,\fp_use:N\l__atableau_yl_fp)--(\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_yl_fp);
                \typeout{ticked~off:)}
            \typeout{finished~tick~####1.}
            }
            \typeout{finished~runner~##1.}
        }
        \typeout{About~to~add~\int_use:N\l__atableau_beads_int~\space~beads~from~#5.}
        \int_step_inline:nn { \l__atableau_beads_int } % finally, add the beads, with labels and styles
        {

            \typeout{adding~bead~##1~with~part=\seq_item:Nn\l__atableau_shape_seq{##1},~style=\seq_item:Nn\l__atableau_style_seq{##1},~text=\seq_item:Nn \l__atableau_text_seq {##1}.}
            % determine the row and column indices for the bead
            \int_set:No \l_tmpa_int { \l__atableau_beads_int - ##1 + \seq_item:Nn \l__atableau_shape_seq {##1} } % beta number
            \int_set:Nn \l__atableau_row_int { \int_div_truncate:nn {\l_tmpa_int} {#4} }
            \int_set:Nn \l__atableau_col_int { \int_mod:nn {\l_tmpa_int} {#4} }

            % determine the bead coordinates
            \__atableau_set_coordinates:nVV {l} \l__atableau_row_int \l__atableau_col_int

            \str_case:VnF \l__atableau_label_tl
            {
               {beta}    { \tl_set:No \l_tmpa_tl { \int_use:N\l_tmpa_int }                     }
               {residue} {
                           \tl_set:No \l_tmpb_tl { \seq_item:Nn \l__atableau_charge_seq {1}}
                           \tl_set:No \l_tmpc_tl { \seq_item:Nn \l__atableau_shape_seq {##1}}
                           \tl_set:No \l_tmpa_tl { \__atableau_residue:nn {\l_tmpb_tl - ##1 + \l_tmpc_tl} {\l__atableau_rows_int} }
                         }
               {row}     { \tl_set:No \l_tmpa_tl { ##1 }                                       }
               {shape}   { \tl_set:No \l_tmpa_tl { \seq_item:Nn \l__atableau_shape_seq {##1} } }
               {}        { \tl_set:No \l_tmpa_tl { \seq_item:Nn \l__atableau_text_seq  {##1} } }
            }
            {
                \msg_error:nnx {aTableau} {unrecognised-abacus-label} { \tl_use:N \l__atableau_label_tl }
            }
            \typeout{~-~placing~bead~at~(\fp_use:N\l__atableau_xl_fp,\fp_use:N\l__atableau_yl_fp),~style=~\seq_item:Nn \l__atableau_style_seq {##1},~label=\tl_use:N\l_tmpa_tl|}
            % draw the bead with style
            \node[atableau/bead, \seq_item:Nn \l__atableau_style_seq {##1}] (\l__atableau_name_tl)
                at (\fp_use:N\l__atableau_xl_fp,\fp_use:N\l__atableau_yl_fp){\__atableau_entry:n {\l_tmpa_tl}};
        }

    \group_end:
}

% braid diagrams:
% Usage:
%  - \braid{a_1,...a_n}   : braid diagram connecting k to a_k
%  - \braid*{a_1,...a_n}  : braid diagram connecting k to a_k with top labels
%  - \braid!{a_1,...a_n}  : braid diagram connecting k to a_k with bottom labels
%  - \braid*!{a_1,...a_n} : braid diagram connecting k to a_k with top and bottom labels
% The command also accepts an optional argument, which is passed to the
% underlying TikZ environment.
\NewDocumentCommand\braid{ O{} s t! m }{%
  \begin{tikzpicture}[rounded~corners, thick, NavyBlue, #1]
    \foreach \pt [count=\c] in {#4}{
      \node[atableau/bead] at (\c,1){};
      \node[atableau/bead] at (\pt,0){};
      \draw[atableau/wall] (\c,1) -- (\pt,0);
    }
    \IfBooleanT{#2}{ \foreach \pt [count=\c] in  {#4} \node at (\c, 1.3) {$\c$}; }
    \IfBooleanT{#3}{ \foreach \pt [count=\c] in  {#4} \node at (\c,-0.3) {$\c$}; }
  \end{tikzpicture}%
}

