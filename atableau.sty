% usage: \__atableau_compute_conjugate_partition:N {seq}
% compute the conjugate partition and store in \l__atableau_conjugate_seq
\cs_new_protected_nopar:Npn \__atableau_compute_conjugate_partition:N #1
{
    \seq_clear:N \l__atableau_conjugate_seq
    \int_zero:N \l_tmpa_int % previous part
    \int_set:No \l__atableau_r_int {\seq_count:N #1}
    \int_while_do:nn {\l__atableau_r_int > 0}
    {
        \int_set:No \l_tmpb_int {\seq_item:NV #1 \l__atableau_r_int }
        \int_step_inline:nn { \l_tmpb_int - \l_tmpa_int }
        {
            \seq_put_right:NV \l__atableau_conjugate_seq \l__atableau_r_int
        }
        \int_set_eq:NN \l_tmpa_int \l_tmpb_int
        \int_decr:N \l__atableau_r_int
    }
}

% usage: \__atableau_set_partition:nn {shape|skew} {csv for partition}
% This function allows the partition to be given either as a comma separated
% list of integers, or as a comma separated list of integers with exponents
% giving the multiplicity of each part. For example, 4,3,3,3,2 and 4,3^3,2
% are both supported.
% TODO? Rewrite using quarks?
\cs_new_protected_nopar:Npn \__atableau_set_partition:nn #1 #2
{
  \seq_clear:c {l__atableau_#1_seq}
  \clist_map_inline:nn {#2} { \__atableau_add_to_partition:nn {#1} {##1} }
}

% add parts to the partition \g__tmpc_seq given input
% of the form k or k^r
\cs_new_protected_nopar:Npn \__atableau_add_to_partition:nn #1 #2
{
    % split #1 on ^: the trailing ^1 sets the exponent to 1 if it's omitted
    \seq_set_split:Nnn \l_tmpa_seq {^} {#2 ^1}
    % given k or k^r, set \l_tmpa_int=k and \l_tmpb_int=r, where r=1 with input k
    \seq_pop_left:NN  \l_tmpa_seq \l_tmpa_tl % part
    \seq_pop_left:NN \l_tmpa_seq \l_tmpb_tl  % exponent
    % now add \l_tmpa_int to \g_tmpb_seq b times
    \int_step_inline:nn {\l_tmpb_tl} { \seq_put_right:ce {l__atableau_#1_seq} {\l_tmpa_tl} }
}

% Young diagrams are drawn using the \Tableau command together with the
% usage: \__atableau_diagram_for_shape:N converts a partition/seq into a
% clist of dots. For example, it replaces the sequence 3,2,2,1 with
% the dot-sequence ~~~,~~,~~,~,
\cs_new_protected_nopar:Npn \__atableau_diagram_for_shape:N #1
{
    \tl_clear:N \l__atableau_entries_tl
    \seq_map_inline:Nn #1
    {
        \tl_put_right:Nx \l__atableau_entries_tl  {\prg_replicate:nn {##1} {{{~}}} ,}
    }
}

% Contents diagrams are drawn using the \Tableau command, with
% usage: \__atableau_shape_to_content:Nn {partition sequence} {charge} supplying the content sequence
\cs_new_protected_nopar:Npn \__atableau_shape_to_content:Nn #1 #2
{
    \tl_clear:N \l__atableau_entries_tl
    \int_zero:N \l__atableau_row_int
    \seq_map_inline:Nn #1
    {
        \int_incr:N \l__atableau_row_int
        \int_step_inline:nn {##1}
        {
            \tl_set:Ne \l_tmpc_tl { \int_eval:n{\seq_item:Nn \l__atableau_charge_seq {#2} ####1 - \l__atableau_row_int} }
            \__atableau_tl_put_right_braced:NV \l__atableau_entries_tl \l_tmpc_tl
        }
        \tl_put_right:Nn \l__atableau_entries_tl {,}
    }
    \typeout{********************* content *********************}
    \typeout{ \l__atableau_entries_tl}
    \typeout{************************************************}
}

% Contents diagrams are drawn using the \Tableau command, with
% usage: \__atableau_shape_to_final:Nn {partition sequence} {charge}
\cs_new_protected_nopar:Npn \__atableau_shape_to_final:Nn #1 #2
{
    % compute conjugate of #1 as \l__atableau_conjugate_seq
    \__atableau_compute_conjugate_partition:N #1
    \seq_clear:N \l_tmpc_seq % construct the tableau in this sequence and then decant
    \int_set:Nn \l__atableau_c_int {\seq_item:Nn \l__atableau_charge_seq {#2} }
    % initialise \l_tmpc_seq -- should not be necessary but otherwise \seq_item:NV fails
    \seq_map_inline:Nn  \l__atableau_conjugate_seq {\seq_put_right:Nn \l_tmpc_seq {}}
    \seq_map_inline:Nn  \l__atableau_conjugate_seq
    {
        \int_zero:N \l__atableau_r_int
        \typeout{final:~adding~##1.}
        \int_step_inline:nn {##1}
        {
            \int_incr:N \l__atableau_r_int  % row index
            \int_incr:N \l__atableau_c_int  % tableau entry
        \typeout{final:~##1->r=\int_use:N\l__atableau_r_int,~c=\int_use:N\l__atableau_c_int}
            \tl_set:Nx \l_tmpa_tl {\seq_item:NV \l_tmpc_seq \l__atableau_r_int }
            \__atableau_tl_put_right_braced:NV \l_tmpa_tl \l__atableau_c_int
            \seq_set_item:Nno \l_tmpc_seq \l__atableau_r_int \l_tmpa_tl
        }
    }
    % finally, unpack \l_tmpc_tl into l__atableau_entries_tl
    \tl_clear:N \l__atableau_entries_tl
    \seq_map_inline:Nn \l_tmpc_seq {\tl_put_right:Nn \l__atableau_entries_tl {##1,}}
    \typeout{********************* final *********************}
    \typeout{ \l__atableau_entries_tl}
    \typeout{************************************************}
}

% Contents diagrams are drawn using the \Tableau command, with
% usage: \__atableau_shape_to_initial:Nn {partition sequence} {charge}
\cs_new_protected_nopar:Npn \__atableau_shape_to_initial:Nn #1 #2
{
    \tl_clear:N \l__atableau_entries_tl
    \int_set:Nn \l__atableau_r_int {\seq_item:Nn \l__atableau_charge_seq {#2} }
    \seq_map_inline:Nn #1
    {
        \int_step_inline:nn {##1}
        {
            \int_incr:N \l__atableau_r_int
            \__atableau_tl_put_right_braced:NV \l__atableau_entries_tl \l__atableau_r_int
        }
        \tl_put_right:Nn \l__atableau_entries_tl {,}
    }
    \typeout{********************* initial *********************}
    \typeout{ \l__atableau_entries_tl}
    \typeout{************************************************}
}

% Hook length diagrams are drawn using the \Tableau command, with
% usage: \__atableau_shape_to_hook:N supplying the sequence of hook lengths
\cs_new_protected_nopar:Npn \__atableau_shape_to_hook:N #1
{
    % compute conjugate of #1 as \l__atableau_conjugate_seq
    \__atableau_compute_conjugate_partition:N #1
    % now construct the hook tableau
    \tl_clear:N \l__atableau_entries_tl
    \int_zero:N \l__atableau_row_int
    \seq_map_inline:Nn #1
    {
        \int_incr:N \l__atableau_row_int
        \int_step_inline:nn {##1}
        {
    \typeout{conjugate:~(\seq_use:Nn \l__atableau_conjugate_seq {,})}
            \tl_set:Ne \l_tmpc_tl { \int_eval:n {##1+\seq_item:Nn \l__atableau_conjugate_seq {####1} -\l__atableau_row_int-####1+1} }
            \__atableau_tl_put_right_braced:NV \l__atableau_entries_tl \l_tmpc_tl
        }
        \tl_put_right:Nn \l__atableau_entries_tl {,}
    }
    \typeout{********************* hook *********************}
    \typeout{ \l__atableau_entries_tl}
    \typeout{************************************************}
}

% Residue diagrams are drawn using the \Tableau command, with
% usage: \__atableau_shape_to_content:Nn {partition sequence} {charge}
\cs_new_protected_nopar:Npn \__atableau_shape_to_residue:Nn #1 #2
{
    \tl_clear:N \l__atableau_entries_tl
    \int_zero:N \l__atableau_row_int
    \typeout{res:~(\seq_use:Nn #1 {,})}
    \seq_map_inline:Nn #1
    {
        \int_incr:N \l__atableau_row_int
    \typeout{m=##1,~r=\int_use:N\l__atableau_row_int}
        \int_step_inline:nn {##1}
        {
        \typeout{residue:~m=##1,~r=\int_use:N\l__atableau_row_int,~c=####1,~charge=\seq_item:Nn \l__atableau_charge_seq {#2}.}
            \int_set:Nn \l_tmpa_int {####1 - \l__atableau_row_int + \seq_item:Nn \l__atableau_charge_seq {#2}}
            \tl_set:Nx \l_tmpc_tl { \__atableau_residue:nn { \l_tmpa_int } {\l__atableau_e_int} }
        \typeout{con=\int_use:N\l_tmpa_int,~res=\l_tmpc_tl,~e=\int_use:N\l__atableau_e_int}
            \__atableau_tl_put_right_braced:Nx \l__atableau_entries_tl \l_tmpc_tl
        }
        \tl_put_right:Nn \l__atableau_entries_tl {,}
    }
    \typeout{********************* residue *********************}
    \typeout{ \l__atableau_entries_tl}
    \typeout{************************************************}
}

% ---------------------------------------------------------------------------
% draw diagram border

% usage: \__atableau_draw_border:nn #1 #2 {name of sequence} {name of style}
\cs_new_protected_nopar:Npn \__atableau_draw_border:nn #1 #2
{
    \int_zero:N \l__atableau_r_int  % row index
    \int_zero:N \l__atableau_c_int  % column index
    \tl_clear:N \l__atableau_border_tl % will hold the border

    \typeout{~-~drawing~border~for~#2.~tabloid=\bool_to_str:N \l__atableau_tabloid_bool,~shape=(\seq_use:cn {l__atableau_#1_seq} {,}).}
    \seq_map_inline:cn {l__atableau_#1_seq}
    {
        \int_set:Nn \l_tmpa_int {0##1}
        \typeout{~-~adding~##1~->~\int_use:N\l_tmpa_int}
        \int_compare:nNnT \l_tmpa_int > {0} % only add borders for nonzero rows
        {
            % compute the endpoints of this row
            \str_if_eq:nnF {skew} {#1}
            {
                \int_set:Nn \l__atableau_c_int { 0\seq_item:Nn \l__atableau_skew_seq {\l__atableau_r_int+1}}
            }
            \__atableau_set_box_coordinates:nVV {a} \l__atableau_r_int \l__atableau_c_int
            \__atableau_set_box_coordinates:nVn {b} \l__atableau_r_int {##1}
            \typeout{outlining~row~\int_use:N\l__atableau_r_int :~(\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_ya_fp)--(\fp_use:N\l__atableau_xb_fp,\fp_use:N\l__atableau_yb_fp),~\bool_to_str:n{ \int_compare_p:n {\l__atableau_r_int = 0} || \l__atableau_tabloid_bool }}
            \bool_if:nTF { \int_compare_p:n {\l__atableau_r_int = 0} || \l__atableau_tabloid_bool }
            {   % add line along "top" of the row
                \tl_put_right:Nx \l__atableau_border_tl {(\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_ya_fp)--(\fp_use:N\l__atableau_xb_fp,\fp_use:N\l__atableau_yb_fp)}

                \__atableau_add_row_ends:
            }
            { % add lines for second and later rows

              % add ends under the row
              \tl_put_left:Nx  \l__atableau_border_tl {(\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_ya_fp)--}
              \tl_put_right:Nx \l__atableau_border_tl {--(\fp_use:N\l__atableau_xb_fp,\fp_use:N\l__atableau_yb_fp)}
              \__atableau_add_row_ends:
            }
            \typeout{border~at~row=\int_use:N\l__atableau_r_int :~\l__atableau_border_tl}
            \int_incr:N \l__atableau_r_int
        }
    }

    % finally, draw the border
    \tl_if_empty:NF \l__atableau_border_tl
    {
      % fill in the last line
      \tl_put_right:Nx \l__atableau_border_tl {(\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_ya_fp)--(\fp_use:N\l__atableau_xb_fp,\fp_use:N\l__atableau_yb_fp)}

      \typeout{****~border=\l__atableau_border_tl}
      \draw[atableau/#2] \l__atableau_border_tl;
    }
}

% usage: \__atableau_add_row_ends: increment the (xa,ya) and (xb,yb) coordinates down
% one row and add the lines at the left and right hand ends of the row to
% \l__atableau_border_tl. If this is a tabloid then we only want to add the
% coordinates but otherwise we joint them up
\cs_new_protected_nopar:Nn \__atableau_add_row_ends:
{
    \bool_if:NTF \l__atableau_conjugate_bool
    {
      % adding to the left-hand side
      \fp_add:Nn \l__atableau_xa_fp {\l__atableau_col_dx_fp*\l__atableau_box_wd_fp}
      \fp_add:Nn \l__atableau_ya_fp {\l__atableau_col_dy_fp*\l__atableau_box_ht_fp}

      % adding to the right-hand side
      \fp_add:Nn \l__atableau_xb_fp {\l__atableau_col_dx_fp*\l__atableau_box_wd_fp}
      \fp_add:Nn \l__atableau_yb_fp {\l__atableau_col_dy_fp*\l__atableau_box_ht_fp}

      \bool_if:NTF \l__atableau_tabloid_bool
      {
        \tl_put_left:Nx  \l__atableau_border_tl {--(\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_ya_fp)}
        \tl_put_right:Nx \l__atableau_border_tl {(\fp_use:N\l__atableau_xb_fp,\fp_use:N\l__atableau_yb_fp)--}
      }
      {
        \tl_put_left:Nx  \l__atableau_border_tl {(\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_ya_fp)--}
        \tl_put_right:Nx \l__atableau_border_tl {--(\fp_use:N\l__atableau_xb_fp,\fp_use:N\l__atableau_yb_fp)}
      }
    }
    {
    \typeout{Adding~}
      % adding to  the left-hand side
      \fp_add:Nn \l__atableau_xa_fp {\l__atableau_row_dx_fp*\l__atableau_box_wd_fp}
      \fp_add:Nn \l__atableau_ya_fp {\l__atableau_row_dy_fp*\l__atableau_box_ht_fp}

      % adding to  the right-hand side
      \fp_add:Nn \l__atableau_xb_fp {\l__atableau_row_dx_fp*\l__atableau_box_wd_fp}
      \fp_add:Nn \l__atableau_yb_fp {\l__atableau_row_dy_fp*\l__atableau_box_ht_fp}

      \bool_if:NTF \l__atableau_tabloid_bool
      {
        \tl_put_left:Nx  \l__atableau_border_tl {(\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_ya_fp)}
        \tl_put_right:Nx \l__atableau_border_tl {(\fp_use:N\l__atableau_xb_fp,\fp_use:N\l__atableau_yb_fp)--}
      }
      {
        \tl_put_left:Nx  \l__atableau_border_tl {(\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_ya_fp)--}
        \tl_put_right:Nx \l__atableau_border_tl {--(\fp_use:N\l__atableau_xb_fp,\fp_use:N\l__atableau_yb_fp)}
      }
    }
}

% ---------------------------------------------------------------------------
% Tableaux

% usage: \__atableau_tableau:n {entries}
% The entries are first primarily because the \Diagram commands need
% to force the entries to expand
\cs_new_protected_nopar:Npn \__atableau_tableau:n #1
{
    \seq_clear:N \l__atableau_shape_seq % record the shape as we go so that we can draw the border
    \int_zero:N \l__atableau_row_int
    \tl_clear:N \l__atableau_styled_nodes_tl
    \bool_if:NT \l__atableau_shifted_bool { \seq_clear:N \l__atableau_skew_seq }
    \typeout{About~to~map!}
    \seq_set_split:Nnn \l__atableau_row_seq {,} {#1}
    \seq_map_inline:Nn \l__atableau_row_seq
    {
        % if shifted is true then add row to the skew shape
        \bool_if:NT \l__atableau_shifted_bool { \seq_put_right:NV \l__atableau_skew_seq \l__atableau_row_int }

        % the leading 0 catches the case when the skew shape has fewer rows than \l__atableau_row_int
        \int_set:Nn \l__atableau_col_int { 0\seq_item:Nn \l__atableau_skew_seq {\l__atableau_row_int+1}}

        \typeout{****~reading:~"##1"}
        % process the entries in this row
        \__atableau_peek_style:nw {draw_entry:nn} ##1 \q_recursion_tail \q_recursion_stop

        % increment the row index, record this in the shape, and repeat
        \int_incr:N \l__atableau_row_int

        % record the shape for drawing out the border
        \seq_put_right:NV \l__atableau_shape_seq \l__atableau_col_int
    }

    % add the nodes with style
    \l__atableau_styled_nodes_tl

    % add any ribbons
    \cs_set_eq:NN \__atableau_update_shape: \relax % don't update shape
    \seq_map_inline:Nn \l__atableau_ribbons_seq {\__atableau_add_ribbon:n {##1}}

    % draw border
    \bool_if:NT \l__atableau_skewwall_bool { \__atableau_draw_border:nn {skew}  {skewwall}  }
    \bool_if:NT \l__atableau_border_bool  { \__atableau_draw_border:nn {shape} {outerwall} }

    % add any snobs
    \seq_map_inline:Nn \l__atableau_snobs_seq {\__atableau_add_ribbon:n {##1}}
}

% usage: \__atableau_set_box_coordinates_normal:nnn [nl] box|tableau| <row> <col>: given the row and columns
% indices, row and col, define the corresponding coordinates in a tableau
%  - \l__atableau_xl_fp : x-coordinates
%  - \l__atableau_yl_fp : y-coordinate
%  - \l__atableau_name_tl : the node name
% Used by both the tableaux commands. Note that row and col both start
% from 0, so the (1,1)-box has row=col=0.
\cs_new_protected_nopar:Npn \__atableau_set_box_coordinates_normal:nnn #1 #2 #3
{
    \tl_set:Nx \l__atableau_name_tl {\l__atableau_prefix_tl-\int_eval:n{1+#2}-\int_eval:n {1+#3}}
    \fp_set:cn {l__atableau_x#1_fp} {\l__atableau_x_fp+((#2+0.5)*\l__atableau_row_dx_fp+(#3+0.5)*\l__atableau_col_dx_fp)*\fp_use:N\l__atableau_box_wd_fp }
    \fp_set:cn {l__atableau_y#1_fp} {\l__atableau_y_fp+((#2+0.5)*\l__atableau_row_dy_fp+(#3+0.5)*\l__atableau_col_dy_fp)*\fp_use:N\l__atableau_box_ht_fp }

    % update the maximum row and column indices for use by multitableau/multidiagrams
    \int_compare:nNnT { \g__atableau_row_max_int } < { #2 }
        { \int_gset:Nn \g__atableau_row_max_int {#2} } % TODO Why global?
    \int_compare:nNnT { \g__atableau_col_max_int } < { #3 }
        { \int_gset:Nn \g__atableau_col_max_int {#3} }
    \typeout{~-~xl=\fp_use:N\l__atableau_xl_fp,~yl=\fp_use:N\l__atableau_yl_fp,~name=\l__atableau_name_tl.}

}

% usage: \__atableau_set_box_coordinates_conjugate:nnn [nl] box|tableau| <row> <col>: given the row and columns
% indices, row and col, define the corresponding coordinates in the conjugate tableau
%  - \l__atableau_xl_fp : x-coordinates
%  - \l__atableau_yl_fp : y-coordinate
%  - \l__atableau_name_tl : the node name
% Used by both the tableaux and abacus commands
\cs_new_protected_nopar:Npn \__atableau_set_box_coordinates_conjugate:nnn #1 #2 #3
{
    \tl_set:Nx \l__atableau_name_tl {\l__atableau_prefix_tl-\int_eval:n{1+#3}-\int_eval:n {1+#2}}
    \fp_set:cn {l__atableau_x#1_fp} {\l__atableau_x_fp+((#3+0.5)*\l__atableau_row_dx_fp+(#2+0.5)*\l__atableau_col_dx_fp)*\fp_use:N\l__atableau_box_wd_fp }
    \fp_set:cn {l__atableau_y#1_fp} {\l__atableau_y_fp+((#3+0.5)*\l__atableau_row_dy_fp+(#2+0.5)*\l__atableau_col_dy_fp)*\fp_use:N\l__atableau_box_ht_fp }

    % update the maximum row and column indices for use by multitableau/multidiagrams
    \int_compare:nNnT { \g__atableau_row_max_int } < { #3 }
        { \int_gset:Nn \g__atableau_row_max_int {#3} }
    \int_compare:nNnT { \g__atableau_col_max_int } < { #2 }
        { \int_gset:Nn \g__atableau_col_max_int {#2} }
    \typeout{~-~xl=\fp_use:N\l__atableau_xl_fp,~yl=\fp_use:N\l__atableau_yl_fp,~name=\l__atableau_name_tl.}

}

% by default , normal coordinates are used
\cs_set_eq:NN \__atableau_set_box_coordinates:nnn \__atableau_set_box_coordinates_normal:nnn

% usage: \__atableau_set_bead_coordinates:nnn [nl] box|tableau| <row> <col>: given the row and columns
% indices, row and col, define the corresponding coordinates in a tableau or abacus:
%  - \l__atableau_xl_fp : x-coordinates
%  - \l__atableau_yl_fp : y-coordinate
%  - \l__atableau_name_tl : the node name
% Used by both the tableaux and abacus commands
\cs_new_protected_nopar:Npn \__atableau_set_bead_coordinates:nnn #1 #2 #3
{
    \tl_set:Nx \l__atableau_name_tl {\l__atableau_prefix_tl-\int_eval:n{#2}-\int_eval:n{#3}}
    \fp_set:cn {l__atableau_x#1_fp} {\l__atableau_x_fp+(#2*\l__atableau_row_dx_fp+#3*\l__atableau_col_dx_fp)*\fp_use:N\l__atableau_abacus_wd_fp }
    \fp_set:cn {l__atableau_y#1_fp} {\l__atableau_y_fp+(#2*\l__atableau_row_dy_fp+#3\l__atableau_col_dy_fp)*\fp_use:N\l__atableau_abacus_ht_fp }

    % update the maximum row and column indices for use by multitableau/multidiagrams
    \int_compare:nNnT { \g__atableau_row_max_int } < { \l__atableau_row_int }
                      { \int_gset_eq:NN \g__atableau_row_max_int \l__atableau_row_int }
    \int_compare:nNnT { \g__atableau_col_max_int } < { \l__atableau_col_int }
                      { \int_gset_eq:NN \g__atableau_col_max_int \l__atableau_col_int }
    \typeout{~-~x#1=\fp_use:c{l__atableau_x#1_fp},~y#1=\fp_use:c{l__atableau_y#1_fp},~name=(\l__atableau_name_tl)~for~bead(#2,#3).}

}

% ---------------------------------------------------------------------------
% node entry

% TODO:
%  - allow use of \hbox_overlap_left:n, \hbox_overlap_center:n, or \hbox_overlap_right:n ???
%  - hook to allow vertical alignment

% We use \hbox_overlap_center:n to ensure that an entry does not change
% the size of the node when it is too large.
\cs_new_protected_nopar:Npn \__atableau_entry_math:n #1
{
  \typeout{~-~math~entry="#1",~color=\l__atableau_text_tl,~font=\l__atableau_font_tl.}
  \hbox_overlap_center:n
    {
        \tl_if_empty:NF \tikz@textcolor {\color{\tikz@textcolor}}
        \tikz@textfont $#1$
    }
}
\cs_new_protected_nopar:Npn \__atableau_entry_text:n #1
{
  \typeout{~-~text~entry="#1",~color=\l__atableau_text_tl,~font=\l__atableau_font_tl.}
  \hbox_overlap_center:n  {\color{\l__atableau_text_tl}\l__atableau_font_tl #1}
}

% By default tableau nodes are typeset in math-mode.
\cs_set_eq:NN \__atableau_entry:n \__atableau_entry_math:n

% usage: \__atableau_draw_entry:nn [style] {entry}
% draw a node entry #2 in the tableau using the style #1
\cs_new_protected_nopar:Npn \__atableau_draw_entry:nn [#1] #2
{
    % exit when we reach the end of the row
    \quark_if_recursion_tail_stop:n {#2}

    \typeout{drawing~with~1=|#1|,~2=|#2|}
    % compute the node name and its (x,y)-coordinates
    \__atableau_set_box_coordinates:nVV {l} \l__atableau_row_int \l__atableau_col_int
    \typeout{drawing~with~style=#1,~entry="#2",row=\int_use:N\l__atableau_row_int,col=\int_use:N\l__atableau_col_int.}

    \tl_if_empty:nTF {#1}
    { % draw box if it has the default styling
        \node[atableau/node](\l__atableau_name_tl) at (\fp_use:N\l__atableau_xl_fp, \fp_use:N\l__atableau_yl_fp)
          {\__atableau_entry:n{#2}};
    }
    { % save the node to \l__atableau_styled_nodes_tl if it is styled
      \tl_put_right:Nx \l__atableau_styled_nodes_tl
      {
          \exp_not:N \node [atableau/node,#1](\l__atableau_name_tl)
              at (\fp_use:N\l__atableau_xl_fp, \fp_use:N\l__atableau_yl_fp)
              {\exp_not:N\__atableau_entry:n{#2}};
      }
    }

    % look for the next entry, or finish
    \int_incr:N \l__atableau_col_int
    \__atableau_peek_style:nw {draw_entry:nn}
}

% ---------------------------------------------------------------------------
% diagrams

% usage: \__atableau_diagram:n {partition}
\cs_new_protected_nopar:Npn \__atableau_diagram:n #1
{
    % convert #1 to the partition \l__atableau_shape_seq
    \__atableau_set_partition:nn {shape} {#1}

    \bool_if:NTF \l__atableau_border_only_bool
    {
        \__atableau_draw_border:nn {shape} {outerwall}
    }
    {
        % depending on \l__atableau_show_tl, generate the tableau entries
        \str_case:VnF \l__atableau_show_tl
        { % TODO: find a better syntax
            {contents} { \__atableau_shape_to_content:Nn \l__atableau_shape_seq {1}}
            {final}    { \__atableau_shape_to_final:Nn   \l__atableau_shape_seq {1}}
            {hooks}    { \__atableau_shape_to_hook:N     \l__atableau_shape_seq }
            {initial}  { \__atableau_shape_to_initial:Nn \l__atableau_shape_seq {1}}
            {residues} { \__atableau_shape_to_residue:Nn \l__atableau_shape_seq {1}}
            {}         { \__atableau_diagram_for_shape:N \l__atableau_shape_seq }
        }
        {
            \msg_error:nnx {aTableau} { unrecognised-label} {\l__atableau_show_tl}
        }
        \__atableau_tableau:V \l__atableau_entries_tl
    }
}


% ---------------------------------------------------------------------------
% multitableau and their diagrams

% Inserts a separator between the different components of multitableau and
% multidiagrams. Requires that \l__atableau_component_int is greater than 1
% and that the requisite flags are set. The location of the separator is
% controlled by
%   - \l__atableau_separation_fp
%   - \g__atableau_col_max_int
%   -\g__atableau_row_max_int
\cs_new_protected_nopar:Npn \__atableau_insert_separator:n #1
{
    \int_compare:nNnT {\l__atableau_component_int} > {0}
    {
    \typeout{*****************}
    \typeout{Separating!~Comp=\int_use:N\l__atableau_component_int,~row~max=\int_use:N\g__atableau_row_max_int,~col~max=\int_use:N\g__atableau_col_max_int,row=\int_use:N\l__atableau_row_int,col=\int_use:N\l__atableau_col_int,~dx=\fp_use:N\l__atableau_col_dx_fp,~dy=\fp_use:N\l__atableau_row_dy_fp,~height=\fp_use:N\l__atableau_box_ht_fp}
        % the rows setting overrides row_max
        \int_compare:nNnT {\l__atableau_rows_int} > {0}
            { \int_gset_eq:NN \g__atableau_row_max_int \l__atableau_rows_int }
        \int_compare:nNnT {\l__atableau_cols_int} > {0}
            { \int_gset_eq:NN \g__atableau_col_max_int \l__atableau_cols_int }
        \__atableau_set_box_coordinates:nVV {l} \g__atableau_row_max_int \g__atableau_col_max_int
        \fp_add:Nn \l__atableau_yl_fp {\l__atableau_row_dy_fp*\l__atableau_box_ht_fp/2}

        \__atableau_set_box_coordinates:nnV {a} {0} \g__atableau_col_max_int
        \fp_add:Nn \l__atableau_xa_fp {\l__atableau_col_dx_fp*\l__atableau_box_wd_fp/2+\l__atableau_separation_fp/2}
        \fp_sub:Nn \l__atableau_ya_fp {\l__atableau_row_dy_fp*\l__atableau_box_ht_fp/2}

        % add the separator
        \str_case:enF {#1} {
        {|} {
                \draw[atableau/separator](\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_ya_fp)--(\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_yl_fp);
            }
        }
        {   % any other separator is assumed to be text
        \typeout{adding~node~text:~"#1"}
            \node[atableau/separator] at (\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_ya_fp){#1};
            \hbox_set:Nn \l_tmpa_box {#1}
            \fp_add:Nn \l__atableau_x_fp {\box_wd:N \l_tmpa_box}
        }

        % finally, increment x by the separation amount
        \fp_set:Nn \l__atableau_x_fp {\l__atableau_xa_fp+\l__atableau_col_dx_fp*\l__atableau_box_wd_fp/2+\l__atableau_separation_fp/2}
    }
    % reset the (row and) column max
    \int_gset:Nn \g__atableau_row_max_int {0}
    \int_gset:Nn \g__atableau_col_max_int {0}
}


% usage: \__atableau_multidiagram:n {entries}
% The entries are first primarily because the \Diagram commands need
% to force the entries to expan
\cs_new_protected_nopar:Npn \__atableau_multidiagram:n #1
{
\typeout{multidiagram:~1="#1"}
      % TODO: add multitableau variants of the show keys
    % track the component
    \int_zero:N \l__atableau_component_int

    % save the prefix name so that we can modify it
    \tl_set_eq:NN \l__atableau_multiprefix_tl \l__atableau_prefix_tl

    % separate the component partitions
    \seq_set_split:Nnn \l__atableau_component_seq {||} {#1}
    \seq_map_inline:Nn \l__atableau_component_seq
    {
    \typeout{Component:~\int_use:N\l__atableau_component_int}
        \__atableau_insert_separator:n \l__atableau_separator_tl
        \int_incr:N \l__atableau_component_int
        \tl_if_eq:nnTF {##1} {...}
           {
               % insert dots
               \typeout{ - adding~separator:~"##1"}
               \__atableau_insert_separator:n {...}
           }
           {
               \typeout{ - adding:~"##1"}
               % convert ##1 to the partition \l__atableau_shape_seq
               \__atableau_set_partition:nn {shape} {##1}
               % generate the dot-sequence for the partition
               \__atableau_diagram_for_shape:N \l__atableau_shape_seq
               \tl_set:No \l__atableau_prefix_tl {prefix=\l__atableau_multiprefix_tl-\int_use:N\l__atableau_component_int}
               \typeout{~-ready~to~add~"\l__atableau_entries_tl"}
               \__atableau_tableau:V \l__atableau_entries_tl
           }
    }
}

% usage: \__atableau_multitableau:n {entries}
% The entries are first primarily because the \Diagram commands need
% to force the entries to expand
\cs_new_protected_nopar:Npn \__atableau_multitableau:n #1
{
\typeout{multitableau:~1="#1"}
    % track the component
    \int_zero:N \l__atableau_component_int

    % save the prefix name so that we can modify it
    \tl_set_eq:NN \l__atableau_multiprefix_tl \l__atableau_prefix_tl

    % separate the entries of the component tableaux
    \seq_set_split:Nnn \l__atableau_component_seq {|} {#1}
    \seq_map_inline:Nn \l__atableau_component_seq
    {
    \typeout{Component~\int_use:N\l__atableau_component_int="##1"}
        \__atableau_insert_separator:n \l__atableau_separator_tl
        \int_incr:N \l__atableau_component_int
        \tl_if_eq:nnTF {##1} {...}
           {
               % insert dots
               \__atableau_insert_separator:n {...}
           }
           {
               % insert tableau
               \tl_set:No \l__atableau_prefix_tl {prefix=\l__atableau_multiprefix_tl-\int_use:N\l__atableau_component_int}
               \__atableau_tableau:n {##1}
           }
    }
}

% ---------------------------------------------------------------------------
% Ribbon tableaux

% usage: \__atableau_ribbon_tableau:n {ribbons}
% Draw a ribbon tableau. The ribbons are specified by
%   (ribbon style) ij sequences of r's and c's with optional style and
%   with text as a subscript. Here i and j are the row and column
%   indices of the head of the ribbon
\cs_new_protected_nopar:Npn \__atableau_ribbon_tableau:n #1
{
\typeout{ribbon~tableau:~1="#1"}
    \seq_clear:N \l__atableau_shape_seq % record the shape as we go to draw the border
    \cs_set_eq:NN \__atableau_update_shape: \__atableau_update_ribbon_tableau_shape:
    \clist_map_inline:nn {#1} { \__atableau_add_ribbon:n {##1} }

    % draw borders
    \bool_if:NT \l__atableau_skewwall_bool { \__atableau_draw_border:nn {skew}  {skewwall}  }
    \bool_if:NT \l__atableau_border_bool  { \__atableau_draw_border:nn {shape} {outerwall} }
}

% usage: \__atableau_add_ribbon:n {ribbon} add a ribbon to the tableau
\cs_new_protected_nopar:Npn \__atableau_add_ribbon:n #1
{
\typeout{ABOUT~to~parse~ribbon~"#1"}
    % reset the sequences that store the node data
    \seq_clear:N \l__atableau_texts_seq  % will contain node text
    \seq_clear:N \l__atableau_styles_seq % will contain node styles
    \seq_clear:N \l__atableau_rcs_seq    % will contain node (row,col)-indices
    \typeout{starting}
    \__atableau_peek_ribbon_style:w #1 \q_recursion_tail \q_recursion_stop
}

% look for (ribbon) style inside parentheses: (style)
\cs_new_protected_nopar:Npn \__atableau_peek_ribbon_style:w
{
\typeout{peeking~for~pstyle}
    \peek_remove_spaces:n { % ignore spaces
      \peek_charcode:NTF (
        { \__atableau_save_ribbon_style:n   }
        { \__atableau_save_ribbon_style:n ()}
    }
}

% read the style (style) and save in \l__atableau_ribbon_style_tl
% and then peek for [style]rc...
\cs_new_protected_nopar:Npn \__atableau_save_ribbon_style:n (#1)
{
\typeout{save_pstyle:~"#1"}
    \tl_set:Nn \l__atableau_ribbon_style_tl {#1}
    \__atableau_peek_style:nw {save_ribbon_head:nnn}
}

% save the style, row and column indices for the head of the ribbon
% and then compute the coordinates of the three "external nodes" in the
% head.
\cs_new_protected_nopar:Npn \__atableau_save_ribbon_head:nnn [#1] #2 #3
{
\typeout{save_head:~#1,~#2,~#3:~->~\int_eval:n{#2-1}~->~\int_eval:n{#3-1}.}
    % save any style
    \seq_put_right:Nx \l__atableau_styles_seq {#1}

    % record the row and column indices of the head
    \int_set:Nn \l__atableau_row_int {#2-1}
    \int_set:Nn \l__atableau_col_int {#3-1}
    \seq_put_right:No \l__atableau_rcs_seq {\int_use:N\l__atableau_row_int}
    \seq_put_right:No \l__atableau_rcs_seq {\int_use:N\l__atableau_col_int}

    % update the shape to include the head node
    \__atableau_update_shape:

    % add initial coordinates to \l__atableau_ribbon_tl
    \__atableau_set_box_coordinates:nVV {l} \l__atableau_row_int \l__atableau_col_int

    % 1. Make (xl,yl) the top corner of the ribbon and add it
    \fp_add:Nn \l__atableau_xl_fp { 0.5*(\l__atableau_col_dx_fp-\l__atableau_row_dx_fp)*\l__atableau_box_wd_fp }
    \fp_add:Nn \l__atableau_yl_fp { 0.5*(\l__atableau_col_dy_fp-\l__atableau_row_dy_fp)*\l__atableau_box_ht_fp }
    \tl_set:Nx \l__atableau_ribbon_tl { (\fp_use:N\l__atableau_xl_fp,\fp_use:N\l__atableau_yl_fp) }

    % 2. Make (xa,ya) the top left of the ribbon and add it on the left (decreasing column)
    \fp_set:Nn \l__atableau_xa_fp {\l__atableau_xl_fp-\l__atableau_col_dx_fp*\l__atableau_box_wd_fp}
    \fp_set:Nn \l__atableau_ya_fp {\l__atableau_yl_fp-\l__atableau_col_dy_fp*\l__atableau_box_ht_fp}
    \tl_put_left:Nx \l__atableau_ribbon_tl { (\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_ya_fp)-- }

    % 3, Make (xb,yb) the bottom right corner and add it on the right (increasing row)
    \fp_set:Nn \l__atableau_xb_fp {\l__atableau_xl_fp+\l__atableau_row_dx_fp*\l__atableau_box_wd_fp}
    \fp_set:Nn \l__atableau_yb_fp {\l__atableau_yl_fp+\l__atableau_row_dy_fp*\l__atableau_box_ht_fp}
    \tl_put_right:Nx \l__atableau_ribbon_tl { --(\fp_use:N\l__atableau_xb_fp,\fp_use:N\l__atableau_yb_fp) }

    \__atableau_peek_ribbon_text:w
}

% peek for subscripted text _{text} in the ribbon
\cs_new_protected_nopar:Npn \__atableau_peek_ribbon_text:w
{
\typeout{peeking~for~text}
    \peek_remove_spaces:n { % ignore spaces
      \peek_charcode_remove:NTF _
        { \__atableau_save_ribbon_text:n }
        {
          \seq_put_right:Nn \l__atableau_texts_seq {} % empty text
          \__atableau_peek_style:nw  {save_ribbon:nn}
        }
    }
}

% save any text for a rode in the ribbon in \l__atableau_texts_seq
\cs_new_protected_nopar:Npn \__atableau_save_ribbon_text:n #1
{
    \seq_put_right:No \l__atableau_texts_seq {#1}
    \__atableau_peek_style:nw  {save_ribbon:nn}
}

% For each successive r and c in the ribbon specification, determine the
% surrpouding coordinates in the ribbon and save any custom styles in
% \l__atableau_styles_seq and then repeat
\cs_new_protected_nopar:Npn \__atableau_save_ribbon:nn [#1] #2
{
   % draw the ribbon when we run out of nodes
   \quark_if_recursion_tail_stop_do:nn {#2} {
    \typeout{
       Ribbon~style:~\l__atableau_ribbon_style_tl,\\
       Node~rows~and~columns:~\seq_use:Nn \l__atableau_rcs_seq {,~}\\
       Node~styles:~\seq_use:Nn \l__atableau_styles_seq {,~}\\
       Node~texts~\seq_use:Nn \l__atableau_texts_seq {,~}\\
    }
    \__atableau_draw_ribbon:
   }

    % move row and col according to the ribbon specification and update
    % the nodes (xa,ya) and (xb,yb) in the ribbon
    \str_case:enF {#2}
    {
        {c} { % move back one column
              \int_decr:N \l__atableau_col_int

              % Move (xa,ya) back one column add it to the ribbon on the left
              \fp_sub:Nn \l__atableau_xa_fp {\l__atableau_col_dx_fp*\l__atableau_box_wd_fp}
              \fp_sub:Nn \l__atableau_ya_fp {\l__atableau_col_dy_fp*\l__atableau_box_ht_fp}
              \tl_put_left:Nx \l__atableau_ribbon_tl { (\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_ya_fp)-- }

              % Move (xb,xb) back one column add it to the ribbon on the right
              \fp_sub:Nn \l__atableau_xb_fp {\l__atableau_col_dx_fp*\l__atableau_box_wd_fp}
              \fp_sub:Nn \l__atableau_yb_fp {\l__atableau_col_dy_fp*\l__atableau_box_ht_fp}
              \tl_put_right:Nx \l__atableau_ribbon_tl { --(\fp_use:N\l__atableau_xb_fp,\fp_use:N\l__atableau_yb_fp) }
            }
        {r} { % move forward one row
              \int_incr:N \l__atableau_row_int

              % Move (xa,ya) forward one row add it to the ribbon on the left
              \fp_add:Nn \l__atableau_xa_fp {\l__atableau_row_dx_fp*\l__atableau_box_wd_fp}
              \fp_add:Nn \l__atableau_ya_fp {\l__atableau_row_dy_fp*\l__atableau_box_ht_fp}
              \tl_put_left:Nx \l__atableau_ribbon_tl { (\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_ya_fp)-- }

              % Move (xb,xb) forward one row add it to the ribbon on the right
              \fp_add:Nn \l__atableau_xb_fp {\l__atableau_row_dx_fp*\l__atableau_box_wd_fp}
              \fp_add:Nn \l__atableau_yb_fp {\l__atableau_row_dy_fp*\l__atableau_box_ht_fp}
              \tl_put_right:Nx \l__atableau_ribbon_tl { --(\fp_use:N\l__atableau_xb_fp,\fp_use:N\l__atableau_yb_fp) }
            }
    }
    {
        \msg_error:nnx {aTableau} {invalid-ribbon-specification} {#2}
    }

    % update the shape to include the new node
    \__atableau_update_shape:

    % save the style and row and column indices
    \seq_put_right:No \l__atableau_styles_seq {#1} % record the style of the head
    \seq_put_right:No \l__atableau_rcs_seq {\int_use:N\l__atableau_row_int} % record the row of the node
    \seq_put_right:No \l__atableau_rcs_seq {\int_use:N\l__atableau_col_int} % record the column of the node

    % check to see if this node has any text
    \__atableau_peek_ribbon_text:w
}


% update the shape of the ribbon tableau using the current values of
% \l__atableau_row_int and \l__atableau_col_int
\cs_new_protected_nopar:Nn \__atableau_update_ribbon_tableau_shape:
{
    \int_step_inline:nn { \l__atableau_row_int+1 - \seq_count:N \l__atableau_shape_seq }
    {
      \seq_put_right:Nn \l__atableau_shape_seq {0}
    }
    \int_compare:nNnT {0\seq_item:Nn \l__atableau_shape_seq {\l__atableau_row_int+1}} < {\l__atableau_col_int+1}
    {
      \seq_set_item:Nox \l__atableau_shape_seq {\l__atableau_row_int+1} { \int_eval:n{\l__atableau_col_int+1} }
    }
}

% \__atableau_draw_ribbon: use the various sequences we have constructed
% to draw the ribbon. We first place the nodes with default styling and
% no text, then draw the ribbon with its supplied style and then,
% finally, add the nodes with custom styling or text.
\cs_new_protected_nopar:Npn \__atableau_draw_ribbon:
{
    % Add the \draw command and the last node to the ribbon
    \fp_add:Nn \l__atableau_xa_fp {\l__atableau_row_dx_fp*\l__atableau_box_wd_fp}
    \fp_add:Nn \l__atableau_ya_fp {\l__atableau_row_dy_fp*\l__atableau_box_ht_fp}
    \tl_put_left:Nx \l__atableau_ribbon_tl { (\fp_use:N\l__atableau_xa_fp, \fp_use:N\l__atableau_ya_fp)-- }

    % add a closing cycle
    \tl_put_right:Nn \l__atableau_ribbon_tl {--cycle}

    % place the nodes that use the default style and, at the same time add the
    % nodes with style to \l__atableau_styled_nodes_tl
    \tl_clear:N \l__atableau_styled_nodes_tl
    \seq_map_inline:Nn \l__atableau_styles_seq
    {
        % text the row and column indices
        \seq_pop_left:NN \l__atableau_texts_seq \l_tmpa_tl
        \seq_pop_left:NN \l__atableau_rcs_seq \l_tmpb_tl
        \int_set:No \l__atableau_row_int \l_tmpb_tl
        \seq_pop_left:NN \l__atableau_rcs_seq  \l_tmpb_tl
        \int_set:No \l__atableau_col_int \l_tmpb_tl
        \__atableau_set_box_coordinates:nVV {l} \l__atableau_row_int \l__atableau_col_int

        \tl_if_empty:eTF {##1\l_tmpa_tl}
        {   % nodes with default style and no text
            \node[atableau/ribbon](\l__atableau_name_tl) at (\fp_use:N\l__atableau_xl_fp, \fp_use:N\l__atableau_yl_fp) {};
        }
        {   % nodes with styling go into \l__atableau_styled_nodes_tl
          \tl_put_right:Nx \l__atableau_styled_nodes_tl
          {
            \exp_not:N \node [atableau/node,##1](\l__atableau_name_tl)
                  at (\fp_use:N\l__atableau_xl_fp, \fp_use:N\l__atableau_yl_fp)
                  {\exp_not:N \__atableau_entry:n{\l_tmpa_tl}};
          }
        }
    }
    % draw the ribbon
    \exp_last_unbraced:Ne\draw{[atableau/innerwall, atableau/ribbon, \l__atableau_ribbon_style_tl]} \l__atableau_ribbon_tl;

    % finally, add the styled nodes
    \l__atableau_styled_nodes_tl
}


% ---------------------------------------------------------------------------

% abacuses

% usage: \__atableau_abacus:nn {#runners} {partition+style}
\cs_new_protected_nopar:Npn \__atableau_abacus:nn #1 #2
{
\typeout{Abacus:~1=#1,~2=#2.}
    \int_set:Nn \l__atableau_cols_int {#1}

    % Extract the bead positions and their styles into
    % \l__atableau_shape_seq, \l__atableau_styles_seq and \l__atableau_text
    % We allow all of the following expressions
    %   m, m^r, [style]m, [style]m^2, *m, *m^2,
    %   m_text, m_text^r, [style]m_text, [style]m_text^2, *m_text, *m_text^2,
    %   m_text^r, [style]m_text^2, *m_text^2
    % where m is a part of the partition \l__atableau_shape_seq and r is
    % its' exponent. First, clear all of the sequences and zero the bead
    % counter
    \seq_clear:N \l__atableau_shape_seq % will record the partition
    \seq_clear:N \l__atableau_styles_seq % will record the bead style
    \seq_clear:N \l__atableau_texts_seq  % will record the bead text
    \int_zero:N \l__atableau_beads_int  % will record the number of beads

    % determine the partition/beta numbers
    \clist_map_inline:nn {#2}
    {
        \__atableau_peek_style:nw {record_style:nn} ##1  \q_recursion_tail \q_recursion_stop
    }

    % unless they have been set, determine the number of abacus rows
    \int_compare:nNnT {\l__atableau_rows_int} = {0}
    {
        \typeout{initial=\int_use:N \l_tmpa_int}
        \int_set:No \l__atableau_rows_int { \int_div_truncate:nn {\l__atableau_beads_int + \seq_item:Nn \l__atableau_shape_seq 1} {#1} }
    }
    \typeout{Abacus~with~\int_use:N\l__atableau_rows_int~\space~rows~and~\int_use:N\l__atableau_cols_int~\space~runners~from~max=\seq_item:Nn \l__atableau_shape_seq 1,~e=#1.}
    % draw the abacus runners
    \int_zero:N \l__atableau_col_int
    \int_step_inline:nn {\l__atableau_cols_int}
    {
        \typeout{~-~adding~runner~##1~<~\int_use:N\l__atableau_cols_int}
        % draw the abacus runners from (xa,ya) to (xb,yb)
        \__atableau_set_bead_coordinates:nno {a} { 0 } { \int_eval:n{##1-1} }
        \__atableau_set_bead_coordinates:noo {b} { \int_eval:n{\l__atableau_rows_int+1} } { \int_eval:n{##1-1} }
    \typeout{~-~Drawing~runner~##1 :~(\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_ya_fp)--(\fp_use:N\l__atableau_xb_fp,\fp_use:N\l__atableau_yb_fp)}
        \draw[atableau/runner] (\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_ya_fp)--(\fp_use:N\l__atableau_xb_fp,\fp_use:N\l__atableau_yb_fp);
        % draw the ticks
        \typeout{~-~About~to~add~\int_use:N\l__atableau_rows_int~\space~ticks~of~width~\fp_use:N\l__atableau_tick_width_fp.}
        \int_zero:N \l__atableau_row_int
        \int_step_inline:nn {\l__atableau_rows_int}
        {
            \typeout{~-~adding~tick~####1~<~\int_use:N\l__atableau_rows_int}
            \__atableau_set_bead_coordinates:noo {l} { \int_eval:n{####1} } { \int_eval:n{##1-1} }
            % add and subtract (half) tick width
            \fp_set:Nn \l__atableau_xa_fp {\l__atableau_xl_fp+\l__atableau_tick_width_fp*\l__atableau_col_dx_fp}
            \fp_set:Nn \l__atableau_ya_fp {\l__atableau_yl_fp+\l__atableau_tick_width_fp*\l__atableau_col_dy_fp}
            \fp_set:Nn \l__atableau_xb_fp {\l__atableau_xl_fp-\l__atableau_tick_width_fp*\l__atableau_col_dx_fp}
            \fp_set:Nn \l__atableau_yb_fp {\l__atableau_yl_fp-\l__atableau_tick_width_fp*\l__atableau_col_dy_fp}
            \draw[atableau/tick] (\fp_use:N\l__atableau_xa_fp,\fp_use:N\l__atableau_ya_fp)--(\fp_use:N\l__atableau_xb_fp,\fp_use:N\l__atableau_yb_fp);
            \typeout{~-~finished~tick~####1.}
        }
        \typeout{~-~finished~runner~##1.}
    }

    % draw the beads on the abacus
    \typeout{~-~About~to~add~\int_use:N\l__atableau_beads_int~\space~beads~from~#2.}
    \int_step_inline:nn { \l__atableau_beads_int } % finally, add the beads, with labels and styles
    {

        \typeout{~-~adding~bead~##1~with~part=\seq_item:Nn\l__atableau_shape_seq{##1},~style=\seq_item:Nn\l__atableau_styles_seq{##1},~text=\seq_item:Nn \l__atableau_texts_seq {##1}.}
        % determine the row and column indices for the bead
        \bool_if:NTF \l__atableau_beta_numbers_bool
        {
            \int_set:No \l_tmpa_int { \seq_item:Nn \l__atableau_shape_seq {##1} } % beta number
        }
        {
            \int_set:No \l_tmpa_int { \l__atableau_beads_int - ##1 + \seq_item:Nn \l__atableau_shape_seq {##1} } % part -> beta number
        }
        \int_set:Nn \l__atableau_row_int { \int_div_truncate:nn {\l_tmpa_int} {\l__atableau_cols_int} }
        \int_set:Nn \l__atableau_col_int { \int_mod:nn {\l_tmpa_int} {\l__atableau_cols_int} }
        \typeout{~-~row=\int_use:N\l__atableau_row_int,~col=\int_use:N\l__atableau_col_int.}

        % determine the bead coordinates: push everything 0.5 of a
        % unit down to allow space of the top of the abacus
        \__atableau_set_bead_coordinates:noV {l} {\int_eval:n{\l__atableau_row_int+1} } \l__atableau_col_int

        \str_case:VnF \l__atableau_show_tl
        {
           {beta}    { \tl_set:No \l_tmpa_tl { \int_use:N\l_tmpa_int }                     }
           {residue} {
                       \tl_set:No \l_tmpb_tl { \seq_item:Nn \l__atableau_charge_seq {1}}
                       \tl_set:No \l_tmpc_tl { \seq_item:Nn \l__atableau_shape_seq {##1}}
                       \tl_set:No \l_tmpa_tl { \__atableau_residue:nn {\l_tmpb_tl - ##1 + \l_tmpc_tl} {\l__atableau_rows_int} }
                     }
           {rows }   { \tl_set:No \l_tmpa_tl { ##1 }                                       }
           {shape}   { \tl_set:No \l_tmpa_tl { \seq_item:Nn \l__atableau_shape_seq {##1} } }
           {}        { \tl_set:No \l_tmpa_tl { \seq_item:Nn \l__atableau_texts_seq  {##1} } }
        }
        {
            \msg_error:nnx {aTableau} {unrecognised-abacus-label} {  \l__atableau_show_tl }
        }
        \typeout{~-~placing~(\int_eval:n{\l__atableau_r_int+1},\int_use:N\l__atableau_col_int)~bead~at~(\fp_use:N\l__atableau_xl_fp,\fp_use:N\l__atableau_yl_fp),~style="\seq_item:Nn \l__atableau_styles_seq {##1}",~label="\l_tmpa_tl"}
        % draw the bead with style
        \tl_set:No \l_tmpb_tl { \seq_item:Nn \l__atableau_styles_seq {##1} }
    \typeout{**~tmpb=\l_tmpb_tl,~name=\l__atableau_name_tl,~xl=\fp_use:N \l__atableau_xl_fp,~yl=\fp_use:N \l__atableau_yl_fp, ~tmpa=\l_tmpa_tl. }
        \exp_last_unbraced:Nx \node{[atableau/bead, \l_tmpb_tl]} (\l__atableau_name_tl)
        at (\fp_use:N\l__atableau_xl_fp,\fp_use:N\l__atableau_yl_fp){\__atableau_entry:x {\l_tmpa_tl}};
        \typeout{bead~placed!!!}
     }
}

% braid diagrams:
% Usage:
%  - \braid{a_1,...a_n}   : braid diagram connecting k to a_k
%  - \braid*{a_1,...a_n}  : braid diagram connecting k to a_k with top labels
%  - \braid!{a_1,...a_n}  : braid diagram connecting k to a_k with bottom labels
%  - \braid*!{a_1,...a_n} : braid diagram connecting k to a_k with top and bottom labels
% The command also accepts an optional argument, which is passed to the
% underlying TikZ environment.
\NewDocumentCommand\braid{ O{} s t! m }{%
  \begin{tikzpicture}[rounded~corners, thick, NavyBlue, #1]
    \foreach \pt [count=\c] in {#4}{
      \node[atableau/bead] at (\c,1){};
      \node[atableau/bead] at (\pt,0){};
      \draw[atableau/wall] (\c,1) -- (\pt,0);
    }
    \IfBooleanT{#2}{ \foreach \pt [count=\c] in  {#4} \node at (\c, 1.3) {$\c$}; }
    \IfBooleanT{#3}{ \foreach \pt [count=\c] in  {#4} \node at (\c,-0.3) {$\c$}; }
  \end{tikzpicture}%
}

