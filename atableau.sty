% applies the settings, sets the coordinates of the origin and then
% ensures that the requested diagram is drawn inside a tikzpicture
% environment.

% \Abacus (x,y) [style] {#runners} {partition}
\NewDocumentCommand\Abacus{ d() O{} m m }
{
    \__atableau_tikzpicture:nnn {#2} {#1} { \__atableau_abacus:nn {#3} {#4} }
}

