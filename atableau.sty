% usage: \__atableau_residue:nn computes the residue of #1 mod #2. This is
% positive integer remainder when dividing by #2. As with \int_mod:n,
% the result is left in the % input stream.
\cs_new_nopar:Npn \__atableau_residue:nn #1 #2
{
    \int_compare:nTF {#1 > 0}
        { \int_mod:nn {#1} {#2} }
        { \int_eval:n {\int_mod:nn {#2 + \int_mod:nn {#1} {#2}} {#2}} }% \int_mod:nn is negative
}
% ---------------------------------------------------------------------------
% Parsing input

% Read the next entry in the input sequence, with any optional style, and give
% this data to the command \__atableau_#1:nn.
\cs_new_protected_nopar:Npn \__atableau_peek_style:nw #1
{
%\typeout{reading~style~and~redirecting~to~#1.}
    \peek_remove_spaces:n { % ignore spaces
      \peek_charcode:NTF [
        { \use:c{__atableau_#1} }
        {
          \peek_charcode_remove:NTF *
            { \use:c{__atableau_#1} [atableau/starstyle] }
            { \use:c{__atableau_#1} [] }
        }
    }
}

% To parse the bead specifications used by \Abacus we need to accept the
% a "bead specification" of the following form
%    [style]m^k_txt
% where the [style] could simply be a *, the m is a part of the partition
% being constructed, the k its exponent and txt is the text for the node.
% Except for m, all of of these components are optional, with the exponent
% being 1 if it is omitted. As is customary, the order of the superscript and
% subscript is interchangeable. To parse these expressions we first use
% usage: \__atableau_peek_style:nw to strip off the style specification, via
% usage: \__atableau_record_style:nn, and then pass between \__atableau_peek_beads:nw and
% usage: \__atableau_record:nn to look ahead for the characters ^ and _ to
% decide which of the following token lists the next character is added to:
\cs_new_protected_nopar:Npn \__atableau_record_style:nn [#1] #2
{
    % clear the bead token lists
    \tl_set:Nn \l__atableau_capture_style_tl {#1}
    \tl_set:Nn \l__atableau_capture_part_tl {#2}
    \tl_clear:N \l__atableau_capture_exp_tl
    \tl_clear:N \l__atableau_capture_txt_tl
    \__atableau_peek_beads:nw {part}
}

% look for a caret or an underscore and pass on to \__atableau_record_bead:nn
\cs_new_protected_nopar:Npn \__atableau_peek_beads:nw #1
{
    \peek_remove_spaces:n { % ignore spaces
      \peek_charcode_remove:NTF _
        { \__atableau_record_bead:nn {txt} {}}
        {
          \peek_charcode_remove:NTF ^ { \__atableau_record_bead:nn {exp} {}}
                                      { \__atableau_record_bead:nn {#1} }
        }
    }
}

\cs_new_protected_nopar:Npn \__atableau_record_bead:nn #1 #2
{
    \quark_if_recursion_tail_stop_do:nn {#2}
    {
        % the data in the sequences \l__atableau_capture_exp_tl times
        \tl_if_empty:NT \l__atableau_capture_exp_tl { \tl_set:Nn \l__atableau_capture_exp_tl {1}}
        \typeout{Saving~part=\l__atableau_capture_part_tl,~style=\l__atableau_capture_style_tl,~text=\l__atableau_capture_txt_tl,~exp=\l__atableau_capture_exp_tl.}
        \int_step_inline:nn { \l__atableau_capture_exp_tl }
        {
        \typeout{~-~ADDING:~part=\l__atableau_capture_part_tl,~txt=\l__atableau_capture_txt_tl,~style=\l__atableau_capture_style_tl.}
            \int_incr:N \l__atableau_beads_int
            \seq_put_right:No \l__atableau_shape_seq {\l__atableau_capture_part_tl}
            \seq_put_right:No \l__atableau_texts_seq  {\l__atableau_capture_txt_tl}
            \seq_put_right:No \l__atableau_styles_seq {\l__atableau_capture_style_tl}
        }
    }
\typeout{Recording~#2~in~#1.}
    \tl_put_right:cn {l__atableau_bead_#1_tl} {#2}
    \__atableau_peek_beads:nw {#1}
}

