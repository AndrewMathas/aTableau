{
    \str_case:en { #1 }
    {
        {english}
        {
          \fp_set:Nn \l__atableau_col_dx_fp {1}
          \fp_set:Nn \l__atableau_col_dy_fp {0}
          \fp_set:Nn \l__atableau_row_dx_fp {0}
          \fp_set:Nn \l__atableau_row_dy_fp {-1}
          \tl_set:Nn \l__atableau_style_tl  {english}
          \tl_set:Nn \l__atableau_shape_tl  {rectangle}
        }
        {french}
        {
          \fp_set:Nn \l__atableau_col_dx_fp {1}
          \fp_set:Nn \l__atableau_col_dy_fp {0}
          \fp_set:Nn \l__atableau_row_dx_fp {0}
          \fp_set:Nn \l__atableau_row_dy_fp {1}
          \tl_set:Nn \l__atableau_style_tl  {french}
          \tl_set:Nn \l__atableau_shape_tl  {rectangle}
        }
        {australian}
        {
          \fp_set:Nn \l__atableau_col_dx_fp {0.5}
          \fp_set:Nn \l__atableau_col_dy_fp {-0.5}
          \fp_set:Nn \l__atableau_row_dx_fp {-0.5}
          \fp_set:Nn \l__atableau_row_dy_fp {-0.5}
          \tl_set:Nn \l__atableau_style_tl  {australian}
          \tl_set:Nn \l__atableau_shape_tl  {diamond}
          \fp_set:Nn \l__atableau_width_fp  {0.7012} % 1/sqrt(2)
          \fp_set:Nn \l__atableau_height_fp {0.7012}
        }
        {ukraine}
        {
          \fp_set:Nn \l__atableau_col_dx_fp {0.5}
          \fp_set:Nn \l__atableau_col_dy_fp {0.5}
          \fp_set:Nn \l__atableau_row_dx_fp {-0.5}
          \fp_set:Nn \l__atableau_row_dy_fp {0.5}
          \tl_set:Nn \l__atableau_style_tl  {ukraine}
          \tl_set:Nn \l__atableau_shape_tl  {diamond}
          \fp_set:Nn \l__atableau_width_fp  {0.7012}
