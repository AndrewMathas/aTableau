          \tl_if_empty:NF \tikz@textfont  {\tl_set:No \l__atableau_font_tl {\tikz@textfont}}
        },
        thin,
    },
    innerwall/.style = {
        draw=\l__atableau_inner_tl,
        rectangle,
        thin,
    },
    outerwall/.style = {
       shift={(\fp_eval:n{-(\l__atableau_row_dx_fp+\l__atableau_col_dx_fp)*\l__atableau_width_fp/2},
               \fp_eval:n{-(\l__atableau_row_dy_fp+\l__atableau_col_dy_fp)*\l__atableau_height_fp/2})},
       line~cap=rect,
       very~thick,
       draw = \l__atableau_outer_tl,
