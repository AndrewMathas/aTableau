% usage: \__atableau_tl_put_right_braced:Nn
% Add DOUBLE braces around it's argument
\cs_new_protected:Nn \__atableau_tl_put_right_braced:Nn
{
  \tl_put_right:Nn #1 { {{#2}} }
}
