% Keys for the package options and their defaults

\keys_define:nn { atableau }
{
    % style switches
    Australian .code:n = \__atableau_set_style:n {australian},
    australian .code:n = \__atableau_set_style:n {australian},

    English    .code:n = \__atableau_set_style:n {english},
    english    .code:n = \__atableau_set_style:n {english},

    French     .code:n = \__atableau_set_style:n {french},
    french     .code:n = \__atableau_set_style:n {french},

    ukraine    .code:n = \__atableau_set_style:n {ukraine},
    Ukraine    .code:n = \__atableau_set_style:n {ukraine},
    Russian    .code:n = \__atableau_set_style:n {ukraine},
    russian    .code:n = \__atableau_set_style:n {ukraine},

    style  .choices:nn = {australian,english,french,ukraine,up,down,left,right}{\__atableau_set_style:n {#1}},
    style   .initial:n = english,

    skew         .code:n = { \tl_set:Nn \l__atableau_type_tl {skew}
                             \__atableau_set_partition:nn {skew} {#1}
                           },
    skew      .initial:n = 0,

    shifted      .code:n = { \tl_set:Nn \l__atableau_type_tl {shifted} },

    tabloid  .bool_set:N = \__atableau_tabloid_bool,
    tabloid  .initial:n  = false,

    type     .choices:nn = {normal,shifted,skew}{\tl_set:Nn \l__atableau_type_tl {#1}},
    type      .initial:n = {normal},

    % tableaux alignment
    align .choice:,
    align/top    .code:n = { \tikzset{baseline=(current bounding box.north)} },
    align/center .code:n = { \tikzset{baseline=(current bounding box.center)} },
    align/centre .code:n = { \tikzset{baseline=(current bounding box.center)} },
    align/bottom .code:n = { \tikzset{baseline=(current bounding box.south)} },
    align/.initial:n     = centre,

    % tableau node name prefix
    prefix .tl_set:N  = \l__atableau_prefix_tl,
    prefix .initial:n =T,

    % tableau colours
    inner~wall  .tl_set:N  = \l__atableau_inner_tl,
    inner~wall  .initial:n = blue!50!white,
    outer~wall  .tl_set:N  = \l__atableau_outer_tl,
    outer~wall  .initial:n = blue!50!black,

    inner~style .code:n    = { \exp_args:Nx \tikzset {atableau/innerwall/.append={#1}} },
    outer~style .code:n    = { \exp_args:Nx \tikzset {atableau/outerwall/.append={#1}} },

    % node height and width
    node~height .fp_set:N  = \l__atableau_height_fp,
    node~height .initial:n = 0.5,
    node~width  .fp_set:N  = \l__atableau_width_fp,
    node~width  .initial:n = 0.5,

    % scaling -- redundant?
    scale       .code:n    = { \__atableau_set_scale:nn {#1}{#1} },
    xscale      .code:n    = { \__atableau_set_scale:nn {#1}{0} },
    yscale      .code:n    = { \__atableau_set_scale:nn {0}{#1} },

    % dot and stars
    dot         .tl_set:N  = \l__atableau_dot_tl,
    dot         .initial:n = \space,
    dotstyle    .code:n    = { \exp_args:Nx \tikzset {atableau/dotstyle/.style={#1}} },
    dotstyle    .initial:n = ,
    star        .tl_set:N  = \l__atableau_star_tl,
    star        .initial:n = \space,
    starstyle   .code:n    = { \exp_args:Nx \tikzset {atableau/starstyle/.style={#1}} },
    starstyle   .initial:n = ,

    % tableaux style
    fill        .tl_set:N  = \l__atableau_fill_tl,
    fill        .initial:n = white,

    font        .tl_set:N  = \l__atableau_font_tl,
    font        .initial:n = ,

    shape       .tl_set:N  = \l__atableau_shape_tl,
    shape       .initial:n = rectangle,

    text        .tl_set:N  = \l__atableau_text_tl,
    text        .initial:n = NavyBlue,

    math~nodes .code:n     = { \cs_set_eq:NN \__atableau_entry:n \__atableau_entry_math:n },
    text~nodes .code:n     = { \cs_set_eq:NN \__atableau_entry:n \__atableau_entry_text:n },

    % multitableaux and diagrams
    separation  .fp_set:N  = \l__atableau_separation_fp,
    separation  .initial:n = 1,
    separator    .tl_set:N = \l__atableau_separator_tl,
    separator    .initial:n = |,
    separator fg .tl_set:N  = \l__atableau_separator_fg_tl,
    separator fg .initial:n = LightSlateBlue,

    xoffsets       .code:n = { \seq_set_from_clist:Nn \l__atableau_xoffsets_seq {#1} },
    yoffsets       .code:n = { \seq_set_from_clist:Nn \l__atableau_toffsets_seq {#1} },
    xoffsets    .initial:n =,
    yoffsets    .initial:n =,

    cols        .int_set:N = \l__atableau_cols_int,
    cols        .initial:n = 0,
    rows        .int_set:N = \l__atableau_rows_int,
    rows        .initial:n = 0,

    % abacus settings
    bead         .tl_set:N = \l__atableau_bead_tl, % bead colour
    bead        .initial:n = blue,

    bead sep     .fp_set:N = \l__atableau_height_fp, % bead separation
    bead sep    .initial:n = 0.5,

    char        .int_set:N = \l__atableau_e_int,
    char        .initial:n = 0,

    charge         .code:n = \seq_set_from_clist:Nn \l__atableau_charge_seq {#1},
    charge      .initial:n = 0,

    label        .tl_set:N = \l__atableau_label_tl,  % automatic bead labelling
    label       .initial:n = ,

    runner       .tl_set:N = \l__atableau_runner_tl, % runner colour
    runner      .initial:n = blue,

    runner sep   .fp_set:N = \l__atableau_width_fp, % runner separation
    runner sep  .initial:n = 0.5,

    tick         .tl_set:N = \l__atableau_tick_tl, % tick colour
    tick        .initial:n = blue,

    tick~width    .code:n = { \fp_set:Nn \l__atableau_tick_width_fp {#1/2} }, % tick width separation
    tick~width .initial:n = 0.1,
}

% ---------------------------------------------------------------------------
% Package commands

% Diagrams are drawn by converting the partition into a dot-sequence, which is
% then drawn using \Tableau

% \Abacus[style] (x,y) {#runner} {partition}
\NewDocumentCommand\Abacus{ O{} d() m m }
{
    \IfNoValueTF{#2}
    { \tikz{ \__atableau_abacus:nnnn {#1} (0,0) {#3} {#4}} }
    {        \__atableau_abacus:nnnn {#1} (#2)  {#3} {#4}  }
}

% \Diagram[style](x,y){shape}
\NewDocumentCommand\Diagram{ O{} d() m }
{
    \group_begin:
      \keys_set:nn { atableau } {dot=x,#1}
      % convert #3 to the partition \l__atableau_shape_seq
      \__atableau_set_partition:nn {shape} {#3}
      % generate the dot-sequence for the partition
      \str_case:VnF \l__atableau_label_tl
      { % TODO
          {content} {\__atableau_shape_to_content:N \l__atableau_shape_seq } % add charge?
          {hook}    {\__atableau_shape_to_hook:N \l__atableau_shape_seq }
          {residue} {\__atableau_shape_to_residue:N \l__atableau_shape_seq } % add charge?
          {}        {\__atableau_shape_to_dots:N \l__atableau_shape_seq }
      }
      {
        \msg_error_text:n {aTableau:~unrecognised~label~\tl_use:N\l__atableau_label_tl}
      }
      \IfNoValueTF{#2}
        { \tikz{\exp_args:NV \__atableau_tableau:nnnn \l__atableau_shape_dotstr_tl {} (0,0) } }
        {       \exp_args:NV \__atableau_tableau:nnnn \l__atableau_shape_dotstr_tl {} (#2)    }
    \group_end:
}

% \Multidiagram [style] (x,y) {entries}
\NewDocumentCommand\Multidiagram{ O{} d() m }
{
    \IfNoValueTF{#2}
      { \tikz{\__atableau_multidiagram:nnnn {#3} {#1} (0,0)} }
      {       \__atableau_multidiagram:nnnn {#3} {#1} (#2)   }
}

% \Multitableau [style] (x,y) {entries}
\NewDocumentCommand\Multitableau{ O{} d() m }
{
    \IfNoValueTF{#2}
      { \tikz{\__atableau_multitableau:nnnn {#3} {#1} (0,0)} }
      {       \__atableau_multitableau:nnnn {#3} {#1} (#2)   }
}

% \RibbonTableau[style](x,y){entries}
\NewDocumentCommand\RibbonTableau{ O{} d() m }
{
    \IfNoValueTF{#2}
      { \tikz{\__atableau_ribbon:nnnn {#3} {#1} (0,0)} }
      {       \__atableau_ribbon:nnnn {#3} {#1} (#2)   }
}

% \ShiftedDiagram[style](x,y){entries}
\NewDocumentCommand\ShiftedDiagram{ O{} d() m }
{
    \Diagram[#1,shifted] (#2) {#3}
}

% \ShiftedTableau[style](x,y){entries}
\NewDocumentCommand\ShiftedTableau{ O{} d() m }
{
    \IfNoValueTF{#2}
      { \tikz{\__atableau_tableau:nnnn {#3} {#1,shifted} (0,0)} }
      {       \__atableau_tableau:nnnn {#3} {#1,shifted} (#2)   }
}

% \SkewDiagram[style](x,y){skew shape}{entries}
\NewDocumentCommand\SkewDiagram{ O{} d() m m }
{
