% Keys for the package options and their defaults
\typeout{STARTING~keys}
\keys_define:nn { atableau }
{
    % style switches
    Australian     .code:n = \__atableau_set_style:nn {tableau} {australian},
    australian     .code:n = \__atableau_set_style:nn {tableau} {australian},

    English        .code:n = \__atableau_set_style:nn {tableau} {english},
    english        .code:n = \__atableau_set_style:nn {tableau} {english},

    French         .code:n = \__atableau_set_style:nn {tableau} {french},
    french         .code:n = \__atableau_set_style:nn {tableau} {french},

    ukrainian      .code:n = \__atableau_set_style:nn {tableau} {ukrainian},
    Ukrainian      .code:n = \__atableau_set_style:nn {tableau} {ukrainian},
    Russian        .code:n = \__atableau_set_style:nn {tableau} {ukrainian},
    russian        .code:n = \__atableau_set_style:nn {tableau} {ukrainian},

    convention .choices:nn = {australian,english,french,ukraine}{\__atableau_set_style:nn {tableau} {#1}},
    convention  .initial:n = english,

    outline    .bool_set:N = \l__atableau_outline_bool,
    outline     .initial:n = true,

    shifted    .bool_set:N = \l__atableau_shifted_bool,
    shifted    .initial:n  = false,

    skew           .code:n = { \__atableau_set_partition:nn {skew} {#1} },
    skew        .initial:n = ,

    skewwall   .bool_set:N = \l__atableau_skewwall_bool,
    skewwall   .initial:n  = false,

    tabloid    .bool_set:N = \l__atableau_tabloid_bool,
    tabloid    .initial:n  = false,

    % tableaux alignment
    align .choice:,
    align/top      .code:n = { \tikzset{baseline=(current~bounding~box.north)} },
    align/center   .code:n = { \tikzset{baseline=(current~bounding~box.center)} },
    align/centre   .code:n = { \tikzset{baseline=(current~bounding~box.center)} },
    align/bottom   .code:n = { \tikzset{baseline=(current~bounding~box.south)} },
    align/      .initial:n = centre,

    % tableau node name prefix
    prefix      .tl_set:N  = \l__atableau_prefix_tl,
    prefix      .initial:n = T,

    % tableau colours
    inner~wall   .tl_set:N = \l__atableau_inner_tl,
    inner~wall  .initial:n = blue!50!white,
    outer~wall   .tl_set:N = \l__atableau_outer_tl,
    outer~wall  .initial:n = blue!50!black,

    inner~style    .code:n = { \exp_args:Nx \tikzset {atableau/innerwall/.append={#1}} },
    outer~style    .code:n = { \exp_args:Nx \tikzset {atableau/outerwall/.append={#1}} },

    % node height and width
    node~height  .fp_set:N = \l__atableau_height_fp,
    node~height .initial:n = 0.5,
    node~width   .fp_set:N = \l__atableau_width_fp,
    node~width  .initial:n = 0.5,

    % scaling -- redundant?
    scale          .code:n = { \__atableau_set_xscale:n {#1}
                               \__atableau_set_yscale:n {#1}
                             },
    xscale         .code:n = { \__atableau_set_xscale:n {#1} },
    yscale         .code:n = { \__atableau_set_yscale:n {#1} },

    starstyle      .code:n = { \exp_args:Nx \tikzset {atableau/starstyle/.style={#1}} },
    starstyle   .initial:n = {fill=blue!20},

    % node styling
    fill         .tl_set:N = \l__atableau_fill_tl,
    fill        .initial:n = white,

    font         .tl_set:N = \l__atableau_font_tl,
    font        .initial:n = ,

    shape        .tl_set:N = \l__atableau_shape_tl,
    shape       .initial:n = rectangle,

    text         .tl_set:N = \l__atableau_text_tl,
    text        .initial:n = NavyBlue,

    math~nodes     .code:n = { \cs_set_eq:NN \__atableau_entry:n \__atableau_entry_math:n },
    text~nodes     .code:n = { \cs_set_eq:NN \__atableau_entry:n \__atableau_entry_text:n },

    ribbons        .code:n = {\seq_set_from_clist:Nn \l__atableau_ribbons_seq {#1}},
    ribbons     .initial:n = ,

    ribbonstyle    .code:n = { \exp_args:Nx \tikzset {atableau/ribbon/.style={#1}} }, %.tl_set:N = \l__atableau_ribbon_style_tl,
    ribbonstyle .initial:n =,

    % multitableaux and diagrams
    separation  .fp_set:N  = \l__atableau_separation_fp,
    separation  .initial:n = 1,
    separator    .tl_set:N = \l__atableau_separator_tl,
    separator   .initial:n = |,
    separator fg .tl_set:N  = \l__atableau_separator_fg_tl,
    separator fg .initial:n = LightSlateBlue,

    xoffsets       .code:n = { \seq_set_from_clist:Nn \l__atableau_xoffsets_seq {#1} },
    yoffsets       .code:n = { \seq_set_from_clist:Nn \l__atableau_toffsets_seq {#1} },
    xoffsets    .initial:n =,
    yoffsets    .initial:n =,

    cols        .int_set:N = \l__atableau_cols_int,
    cols        .initial:n = 0,
    rows        .int_set:N = \l__atableau_rows_int,
    rows        .initial:n = 0,

    % abacus settings
    south          .code:n = \__atableau_set_style:nn {abacus} {south},
    east           .code:n = \__atableau_set_style:nn {abacus} {east},
    north          .code:n = \__atableau_set_style:nn {abacus} {north},
    west           .code:n = \__atableau_set_style:nn {abacus} {west},
    orientation .choices:nn = {north,south,east,west}{\__atableau_set_style:nn {abacus}{#1}},
    orientation .initial:n = south,

    bead         .tl_set:N = \l__atableau_bead_tl, % bead colour
    bead        .initial:n = blue,

    bead sep     .fp_set:N = \l__atableau_height_fp, % bead separation
    bead sep    .initial:n = 0.5,

    e           .int_set:N = \l__atableau_e_int,
    e           .initial:n = 0,

    charge         .code:n = \seq_set_from_clist:Nn \l__atableau_charge_seq {#1},
    charge      .initial:n = 0,

    label        .tl_set:N = \l__atableau_label_tl,  % automatic bead labelling
    label       .initial:n = ,

    runner       .tl_set:N = \l__atableau_runner_tl, % runner colour
    runner      .initial:n = blue,

    runner sep   .fp_set:N = \l__atableau_width_fp, % runner separation
    runner sep  .initial:n = 0.5,

    tick         .tl_set:N = \l__atableau_tick_tl, % tick colour
    tick        .initial:n = blue,

    tick~width    .code:n = { \fp_set:Nn \l__atableau_tick_width_fp {#1/2} }, % (half) tick width separation
    tick~width .initial:n = 0.1,
}

% we want to hijack some of the TikZ node keys
\keys_define:nn {atableau/node}
{
    text        .tl_set:N = \l__atableau_text_tl,
    font        .tl_set:N = \l__atableau_font_tl,

    atableau .code:n ={},

    % discard all other keys
    unknown .code:n = {},
}

\typeout{FINISHED~keys}
% ---------------------------------------------------------------------------
% Package commands

% Diagrams are drawn by converting the partition into a dot-sequence, which is
% then drawn using \Tableau

% \Abacus (x,y) [style] {#runner} {partition}
\NewDocumentCommand\Abacus{ d() O{} m m }
{
    \IfNoValueTF{#1}
    { \tikz{ \__atableau_abacus:nnnn {#2} (0,0) {#3} {#4}} }
    {        \__atableau_abacus:nnnn {#2} (#1)  {#3} {#4}  }
}

% \Diagram (x,y) [style] {shape}
\NewDocumentCommand\Diagram{ d() O{} m }
{
    \group_begin:
      \__atableau_set_style:nV {tableau} \l__atableau_tableau_style_tl
      \keys_set:nn { atableau } {#2}
      % convert #3 to the partition \l__atableau_shape_seq
      \__atableau_set_partition:nn {shape} {#3}
      % generate the dot-sequence for the partition
      \str_case:VnF \l__atableau_label_tl
      { % TODO: find a better syntax
          {contents} { \__atableau_shape_to_content:Nn \l__atableau_shape_seq {1}}
          {final}    { \__atableau_shape_to_final:Nn   \l__atableau_shape_seq {1}}
          {hooks}    { \__atableau_shape_to_hook:N     \l__atableau_shape_seq }
          {initial}  { \__atableau_shape_to_initial:Nn \l__atableau_shape_seq {1}}
          {residues} { \__atableau_shape_to_residue:Nn \l__atableau_shape_seq {1}}
          {}         { \__atableau_diagram_for_shape:N \l__atableau_shape_seq }
      }
      {
          \msg_error:nnx {aTableau} { unrecognised-label} {\tl_use:N\l__atableau_label_tl}
      }
      \IfNoValueTF{#1}
        { \tikz{\exp_args:NV \__atableau_tableau:nnnn \l__atableau_entries_tl {} (0,0) } }
        {     \exp_args:NV \__atableau_tableau:nnnn \l__atableau_entries_tl {} (#1)    }
    \group_end:
}

