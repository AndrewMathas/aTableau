\cs_new_nopar:Npn \__atableau_set_style:n #1
{
    \str_case:enF { #1 }
    {
        % tableau styles
        {english}
        {
          \fp_set:Nn \l__atableau_col_dx_fp {1}
          \fp_set:Nn \l__atableau_col_dy_fp {0}
          \fp_set:Nn \l__atableau_row_dx_fp {0}
          \fp_set:Nn \l__atableau_row_dy_fp {-1}
          \tl_set:Nn \l__atableau_shape_tl  {rectangle}
        }
        {french}
        {
          \fp_set:Nn \l__atableau_col_dx_fp {1}
          \fp_set:Nn \l__atableau_col_dy_fp {0}
          \fp_set:Nn \l__atableau_row_dx_fp {0}
          \fp_set:Nn \l__atableau_row_dy_fp {1}
          \tl_set:Nn \l__atableau_shape_tl  {rectangle}
        }
        {australian}
        {
          \fp_set:Nn \l__atableau_col_dx_fp {0.5}
          \fp_set:Nn \l__atableau_col_dy_fp {-0.5}
          \fp_set:Nn \l__atableau_row_dx_fp {-0.5}
          \fp_set:Nn \l__atableau_row_dy_fp {-0.5}
          \tl_set:Nn \l__atableau_shape_tl  {diamond}
          \fp_set:Nn \l__atableau_width_fp  {0.7012} % 1/sqrt(2)
          \fp_set:Nn \l__atableau_height_fp {0.7012}
        }
        {ukraine}
        {
          \fp_set:Nn \l__atableau_col_dx_fp {0.5}
          \fp_set:Nn \l__atableau_col_dy_fp {0.5}
          \fp_set:Nn \l__atableau_row_dx_fp {-0.5}
          \fp_set:Nn \l__atableau_row_dy_fp {0.5}
          \tl_set:Nn \l__atableau_shape_tl  {diamond}
          \fp_set:Nn \l__atableau_width_fp  {0.7012}
          \fp_set:Nn \l__atableau_height_fp {0.7012}
        }
        {russian}
        {
            \__atableau_set_style:n {ukraine}
        }

        % abacus styles
        {down}
        {
          \fp_set:Nn \l__atableau_col_dx_fp {1}
          \fp_set:Nn \l__atableau_col_dy_fp {0}
          \fp_set:Nn \l__atableau_row_dx_fp {0}
          \fp_set:Nn \l__atableau_row_dy_fp {-1}
          \tl_set:Nn \l__atableau_shape_tl  {circle}
          \fp_set:Nn \l__atableau_width_fp  {0.5}
          \fp_set:Nn \l__atableau_height_fp {0.5}
        }
        {up}
        {
          \fp_set:Nn \l__atableau_col_dx_fp {1}
          \fp_set:Nn \l__atableau_col_dy_fp {0}
          \fp_set:Nn \l__atableau_row_dx_fp {0}
          \fp_set:Nn \l__atableau_row_dy_fp {1}
          \tl_set:Nn \l__atableau_shape_tl  {circle}
          \fp_set:Nn \l__atableau_width_fp  {0.5}
          \fp_set:Nn \l__atableau_height_fp {0.5}
        }
        {right}
        {
          \fp_set:Nn \l__atableau_col_dx_fp {0}
          \fp_set:Nn \l__atableau_col_dy_fp {-1}
          \fp_set:Nn \l__atableau_row_dx_fp {1}
          \fp_set:Nn \l__atableau_row_dy_fp {0}
          \tl_set:Nn \l__atableau_shape_tl  {circle}
          \fp_set:Nn \l__atableau_width_fp  {0.5}
          \fp_set:Nn \l__atableau_height_fp {0.5}
        }
        {left}
        {
          \fp_set:Nn \l__atableau_col_dx_fp {0}
          \fp_set:Nn \l__atableau_col_dy_fp {1}
          \fp_set:Nn \l__atableau_row_dx_fp {-1}
          \fp_set:Nn \l__atableau_row_dy_fp {0}
          \tl_set:Nn \l__atableau_shape_tl  {circle}
          \fp_set:Nn \l__atableau_width_fp  {0.5}
          \fp_set:Nn \l__atableau_height_fp {0.5}
        }

    }
    {
    \msg_error_text:n{ aTableau:~unrecognised~style~#1.}
    }
    % TODO: remove as currently not used anywhere...
    \tl_set:Nn \l__atableau_style_tl {#1}
}

% \__atableau_set_scale:nn {x-scale}{y-scale} : rescale the node dimensions
\cs_new_protected_nopar:Npn \__atableau_set_scale:nn #1 #2
{
    \fp_compare:nNnT {#1} > {0}
    {
        \fp_set:Nn \l__atableau_width_fp      {#1*\l__atableau_width_fp}
        \fp_set:Nn \l__atableau_separation_fp {#1*\l__atableau_separation_fp }
    }
    \fp_compare:nNnT {#2} > {0}
    {
        \fp_set:Nn \l__atableau_height_fp      {#2*\l__atableau_height_fp}
    }
}

