% ---------------------------------------------------------------------------
% TikZ styles

\tikzset{
  % all tikz settings are in the atableau family
  atableau/.is~family, atableau/.cd,
    % style for tableau boxes
    node/.style = {
        anchor         = center,
        inner~sep      = 0pt,
        draw           = \l__atableau_inner_tl,
        fill           = \l__atableau_fill_tl,
        minimum~height = \fp_use:N \l__atableau_box_ht_fp cm,
        minimum~width  = \fp_use:N \l__atableau_box_wd_fp cm,
        shape          = \l__atableau_box_shape_tl,
        thin,
    },
    % inner tableau wall
    innerwall/.style = {
        draw=\l__atableau_inner_tl,
        rectangle,
        thin,
    },
    % outer tableau wall
    outerwall/.style = {
       shift={(\fp_eval:n{-(\l__atableau_row_dx_fp+\l__atableau_col_dx_fp)*\l__atableau_box_wd_fp/2},
               \fp_eval:n{-(\l__atableau_row_dy_fp+\l__atableau_col_dy_fp)*\l__atableau_box_ht_fp/2})},
       line~cap=rect,
       very~thick,
       draw = \l__atableau_outer_tl,
    },
    % default ribbon style
    ribbon/.style = {
        anchor         = center,
        inner~sep      = 0pt,
        minimum~height = \fp_use:N \l__atableau_box_ht_fp cm,
        minimum~width  = \fp_use:N \l__atableau_box_wd_fp cm,
        shape          = \l__atableau_box_shape_tl,
    },
    % default separator text style
    separator/.style = {
       text            = \l__atableau_separator_fg_tl,
    },
    % style for skew walls
    skewwall/.style = {
       shift={(\fp_eval:n{-(\l__atableau_row_dx_fp+\l__atableau_col_dx_fp)*\l__atableau_box_wd_fp/2},
               \fp_eval:n{-(\l__atableau_row_dy_fp+\l__atableau_col_dy_fp)*\l__atableau_box_ht_fp/2})},
       thick,
       draw=LightSkyBlue,
       fill=LightSkyBlue!10,
    },
    % star style
    starstyle/.style = {
        fill = \l__atableau_inner_tl,
        opacity = 0.2,
    },
    % abacus bead styles
    bead/.style={
        anchor         = center,
        inner~sep      = 0pt,
        shading        = ball,
        font           = \l__atableau_font_tl,
        ball~color     = \l__atableau_bead_tl,
        minimum~height = \fp_to_decimal:N \l__atableau_bead_size_fp cm,
        minimum~width  = \fp_to_decimal:N \l__atableau_bead_size_fp cm,
        shape          = \l__atableau_bead_shape_tl,
        text           = \l__atableau_bead_text_tl,
    },
    % abacus styles
    runner/.style={
        very~thick,
        draw = \l__atableau_runner_tl,
    },
    % abacus tick styles
    tick/.style = {
        thin,
        draw = \l__atableau_tick_tl,
    },
}

% ---------------------------------------------------------------------------
% usage: \__atableau_set_style:nn {abacus|tableau} {style}
% sets the basic styles for the tableaux and abacus commands
\cs_new_nopar:Npn \__atableau_set_style:nn #1 #2
{
\typeout{setting~style:~#1/#2.}
    \str_case:enF { #1/#2 }
    {
      {tableau/english}
        {
          \fp_set:Nn \l__atableau_col_dx_fp {1}
          \fp_set:Nn \l__atableau_col_dy_fp {0}
          \fp_set:Nn \l__atableau_row_dx_fp {0}
          \fp_set:Nn \l__atableau_row_dy_fp {-1}
          \fp_set:Nn \l__atableau_box_ht_fp {\l__atableau_yscale_fp*0.5}
          \fp_set:Nn \l__atableau_box_wd_fp {\l__atableau_xscale_fp*0.5}
          \tl_set:Nn \l__atableau_box_shape_tl {rectangle}
        }
      {tableau/french}
        {
          \fp_set:Nn \l__atableau_col_dx_fp {1}
          \fp_set:Nn \l__atableau_col_dy_fp {0}
          \fp_set:Nn \l__atableau_row_dx_fp {0}
          \fp_set:Nn \l__atableau_row_dy_fp {1}
          \fp_set:Nn \l__atableau_box_ht_fp {\l__atableau_yscale_fp*0.5}
          \fp_set:Nn \l__atableau_box_wd_fp {\l__atableau_xscale_fp*0.5}
          \tl_set:Nn \l__atableau_box_shape_tl {rectangle}
        }
      {tableau/australian}
        {
          \fp_set:Nn \l__atableau_col_dx_fp {0.5}
          \fp_set:Nn \l__atableau_col_dy_fp {-0.5}
          \fp_set:Nn \l__atableau_row_dx_fp {-0.5}
          \fp_set:Nn \l__atableau_row_dy_fp {-0.5}
          \fp_set:Nn \l__atableau_box_ht_fp {\l__atableau_yscale_fp*0.7012} % 1/sqrt(2)
          \fp_set:Nn \l__atableau_box_wd_fp {\l__atableau_xscale_fp*0.7012}
          \tl_set:Nn \l__atableau_box_shape_tl {diamond}
        }
      {tableau/ukrainian}
        {
          \fp_set:Nn \l__atableau_col_dx_fp {0.5}
          \fp_set:Nn \l__atableau_col_dy_fp {0.5}
          \fp_set:Nn \l__atableau_row_dx_fp {-0.5}
          \fp_set:Nn \l__atableau_row_dy_fp {0.5}
          \fp_set:Nn \l__atableau_box_ht_fp {\l__atableau_yscale_fp*0.7012}
          \fp_set:Nn \l__atableau_box_wd_fp {\l__atableau_xscale_fp*0.7012}
          \tl_set:Nn \l__atableau_box_shape_tl {diamond}
        }
      {tableau/russian}
        {
          \__atableau_set_style:nn {tableau} {ukrainian}
        }
      {abacus/south}
        {
          \fp_set:Nn \l__atableau_col_dx_fp {1}
          \fp_set:Nn \l__atableau_col_dy_fp {0}
          \fp_set:Nn \l__atableau_row_dx_fp {0}
          \fp_set:Nn \l__atableau_row_dy_fp {-1}
          \fp_set:Nn \l__atableau_box_ht_fp {\l__atableau_yscale_fp*0.5}
          \fp_set:Nn \l__atableau_box_wd_fp {\l__atableau_xscale_fp*0.5}
          \tl_set:Nn \l__atableau_bead_shape_tl  {circle}
        }
      {abacus/north}
        {
          \fp_set:Nn \l__atableau_col_dx_fp {1}
          \fp_set:Nn \l__atableau_col_dy_fp {0}
          \fp_set:Nn \l__atableau_row_dx_fp {0}
          \fp_set:Nn \l__atableau_row_dy_fp {1}
          \tl_set:Nn \l__atableau_bead_shape_tl  {circle}
          \fp_set:Nn \l__atableau_box_wd_fp {\l__atableau_xscale_fp*0.5}
          \fp_set:Nn \l__atableau_box_ht_fp {\l__atableau_yscale_fp*0.5}
        }
      {abacus/east}
        {
          \fp_set:Nn \l__atableau_col_dx_fp {0}
          \fp_set:Nn \l__atableau_col_dy_fp {-1}
          \fp_set:Nn \l__atableau_row_dx_fp {1}
          \fp_set:Nn \l__atableau_row_dy_fp {0}
          \tl_set:Nn \l__atableau_bead_shape_tl  {circle}
          \fp_set:Nn \l__atableau_box_wd_fp {\l__atableau_xscale_fp*0.5}
          \fp_set:Nn \l__atableau_box_ht_fp {\l__atableau_yscale_fp*0.5}
      }
      {abacus/west}
        {
          \fp_set:Nn \l__atableau_col_dx_fp {0}
          \fp_set:Nn \l__atableau_col_dy_fp {1}
          \fp_set:Nn \l__atableau_row_dx_fp {-1}
          \fp_set:Nn \l__atableau_row_dy_fp {0}
          \tl_set:Nn \l__atableau_bead_shape_tl  {circle}
          \fp_set:Nn \l__atableau_box_wd_fp {\l__atableau_xscale_fp*0.5}
          \fp_set:Nn \l__atableau_box_ht_fp {\l__atableau_yscale_fp*0.5}
        }
    }
    {
        \msg_error:nnx {aTableau} {unrecognised-style} {#1/#2}
    }
    % remember the style to make it persistent
\typeout{style~set}
    \tl_set:cn {l__atableau_#1_style_tl} {#2}
}

% usage: \__atableau_set_xscale:n {x-scale} : rescale the x-dimension
\cs_new_protected_nopar:Npn \__atableau_set_xscale:n #1
{
    \fp_set:Nn \l__atableau_xscale_fp     {#1}
    \fp_set:Nn \l__atableau_abacus_wd_fp  {#1*\l__atableau_abacus_wd_fp}
    \fp_set:Nn \l__atableau_box_wd_fp     {#1*\l__atableau_box_wd_fp}
    \fp_set:Nn \l__atableau_separation_fp {#1*\l__atableau_separation_fp }
}
% usage: \__atableau_set_yscale:n {y-scale} : rescale the y-dimension
\cs_new_protected_nopar:Npn \__atableau_set_yscale:n #1
{
    \fp_set:Nn \l__atableau_yscale_fp     {#1}
    \fp_set:Nn \l__atableau_abacus_ht_fp   {#1*\l__atableau_abacus_ht_fp}
    \fp_set:Nn \l__atableau_box_ht_fp      {#1*\l__atableau_box_ht_fp}
}

