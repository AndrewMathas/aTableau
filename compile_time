#! /usr/bin/env bash

# In an attempt to control speed regressions, this script records how
# long it takes to compile the atableau manual in manual_times, together
# with the date, version number and number of pages. We compile twice so
# that we get the "real" compile time. For comparison purposes, the same
# computer should be used because, for example, the manual takes more
# than twice as long to compile on an older imac than on a macbook pro M4.

# Andrew Mathas April, 2025

RECORD_IN="manual_times"

usage() {
  cat <<END
usage: record+compile_time [-h] [--record]

Determine the compile time for the current version of the aTableau manual.

  --record: record the compile time, version number and number of pages in $TIMES
END
  exit 1
}

save_record=false

# parse command line arguments
while [[ $# -ne 0 ]]; do
  case $1 in
    --record) shift && save_record=true ;;
    *) usage && exit ;;
  esac
done


echo "Compiling aTableau manual. Recording the compile time: ${save_record}"
sleep 2
start_time=$(date +%s)
pdflatex atableau
end_time=$(date +%s)
time=$(echo "$end_time - $start_time"  | bc)
pages=$(gawk '/Output written on atableau/ {print substr($5,2,2)}' atableau.log)
record=$(date "+%Y-%m-%d: $(git describe --tag --abbrev=0)   ${pages} pages   ${time} seconds" )

cat $RECORD_IN
echo
echo "New time:"
echo "$record"

if [ "$save_record" = true ]; then
  # append the new compilation time to manual_times
  echo $record >> $RECORD_IN
fi


